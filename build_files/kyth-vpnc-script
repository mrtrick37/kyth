#!/bin/bash
# kyth-vpnc-script: vpnc-script wrapper with systemd-resolved DNS support.
# Passed to openconnect via: --script /usr/libexec/kyth-vpnc-script
#
# Fedora's /etc/resolv.conf is a symlink to systemd-resolved's stub resolver
# (127.0.0.53). The stock vpnc-script writes DNS servers to /etc/resolv.conf,
# which has no effect on the actual resolver. This script calls resolvectl
# instead, pushing VPN DNS servers directly into systemd-resolved per-interface
# so split-DNS works correctly.

set -euo pipefail

# Delegate routing and IP setup to the standard vpnc-script.
# On disconnect this also tears down routes; we revert DNS ourselves after.
if [[ -x /etc/vpnc/vpnc-script ]]; then
    /etc/vpnc/vpnc-script 2>/dev/null || true
fi

case "${reason:-}" in
    connect|reconnect)
        dns_servers=()
        for ip in ${INTERNAL_IP4_DNS:-} ${INTERNAL_IP6_DNS:-}; do
            [[ -n "$ip" ]] && dns_servers+=("$ip")
        done

        domains=()
        for d in ${CISCO_DEF_DOMAIN:-} ${CISCO_SPLIT_DNS:-}; do
            [[ -n "$d" ]] && domains+=("$d")
        done

        if [[ ${#dns_servers[@]} -gt 0 && -n "${TUNDEV:-}" ]]; then
            resolvectl dns "$TUNDEV" "${dns_servers[@]}"
            if [[ ${#domains[@]} -gt 0 ]]; then
                resolvectl domain "$TUNDEV" "${domains[@]}" "~."
            else
                resolvectl domain "$TUNDEV" "~."
            fi
            resolvectl default-route "$TUNDEV" yes 2>/dev/null || true
            logger -t kyth-vpnc "DNS set on $TUNDEV: ${dns_servers[*]}"
        fi
        ;;

    disconnect)
        [[ -n "${TUNDEV:-}" ]] && resolvectl revert "$TUNDEV" 2>/dev/null || true
        ;;
esac
