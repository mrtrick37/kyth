#!/usr/bin/env python3
"""
kyth-telem — MangoHud frame-time telemetry collector for KythOS.

User daemon that watches for MangoHud CSV output files, parses them into a
SQLite database, and computes per-session performance summaries.

MangoHud config injection: on startup the daemon writes (or appends) the
output_folder directive into ~/.config/MangoHud/MangoHud.conf so that
MangoHud logs are captured automatically without requiring the user to
configure it manually.

Database: ~/.local/share/kyth/telemetry.db  (read by System Hub)
Sessions: ~/.local/share/kyth/gaming-sessions/  (MangoHud CSV landing zone)

Signal SIGHUP: re-scan immediately.
"""
from __future__ import annotations

import csv
import json
import logging
import os
import re
import signal
import sqlite3
import sys
import time
from datetime import datetime
from pathlib import Path

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

_HOME = Path.home()
DATA_DIR   = _HOME / ".local/share/kyth"
SESSIONS_DIR = DATA_DIR / "gaming-sessions"
DB_PATH    = DATA_DIR / "telemetry.db"
MANGOHUD_CONF = _HOME / ".config/MangoHud/MangoHud.conf"

LOG = logging.getLogger("kyth-telem")

_SCAN_INTERVAL = 10      # seconds between filesystem polls
_MIN_FILE_AGE  = 15      # seconds old before we consider a CSV stable/complete

# ---------------------------------------------------------------------------
# MangoHud config injection
# ---------------------------------------------------------------------------

def ensure_mangohud_output() -> None:
    MANGOHUD_CONF.parent.mkdir(parents=True, exist_ok=True)
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)

    output_line = f"output_folder={SESSIONS_DIR}"

    if MANGOHUD_CONF.exists():
        text = MANGOHUD_CONF.read_text()
        if re.search(r"^\s*output_folder\s*=", text, re.MULTILINE):
            # already configured — update if pointing elsewhere
            new_text = re.sub(
                r"^\s*output_folder\s*=.*$",
                output_line,
                text,
                flags=re.MULTILINE,
            )
            if new_text != text:
                MANGOHUD_CONF.write_text(new_text)
                LOG.info("Updated MangoHud output_folder → %s", SESSIONS_DIR)
            return
        # Append to existing config
        with open(MANGOHUD_CONF, "a") as f:
            f.write(f"\n# Added by kyth-telem\n{output_line}\n")
    else:
        MANGOHUD_CONF.write_text(f"# KythOS telemetry logging\n{output_line}\n")

    LOG.info("Configured MangoHud output_folder → %s", SESSIONS_DIR)


# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

SCHEMA = """
CREATE TABLE IF NOT EXISTS sessions (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    game_name       TEXT NOT NULL,
    executable      TEXT,
    launcher        TEXT,
    source_file     TEXT UNIQUE,
    started_at      INTEGER,
    ended_at        INTEGER,
    duration_s      REAL,
    avg_fps         REAL,
    p1_low_fps      REAL,
    p01_low_fps     REAL,
    stutter_count   INTEGER,
    peak_gpu_temp   REAL,
    peak_vram_mb    REAL,
    avg_cpu_load    REAL,
    avg_gpu_load    REAL,
    gpu_name        TEXT,
    cpu_name        TEXT,
    kernel          TEXT,
    driver          TEXT,
    scheduler       TEXT,
    ingested_at     INTEGER
);

CREATE TABLE IF NOT EXISTS frames (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id  INTEGER NOT NULL REFERENCES sessions(id) ON DELETE CASCADE,
    ts          REAL,
    fps         REAL,
    frametime   REAL,
    cpu_load    REAL,
    gpu_load    REAL,
    cpu_temp    REAL,
    gpu_temp    REAL,
    vram_mb     REAL
);

CREATE INDEX IF NOT EXISTS idx_frames_session ON frames(session_id);
CREATE INDEX IF NOT EXISTS idx_sessions_started ON sessions(started_at DESC);
"""


def open_db() -> sqlite3.Connection:
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(DB_PATH), timeout=10)
    conn.executescript(SCHEMA)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA synchronous=NORMAL")
    return conn


def already_ingested(conn: sqlite3.Connection, source_file: str) -> bool:
    row = conn.execute(
        "SELECT 1 FROM sessions WHERE source_file = ?", (source_file,)
    ).fetchone()
    return row is not None


# ---------------------------------------------------------------------------
# Game name detection
# ---------------------------------------------------------------------------

def _proc_env(pid: int, key: str) -> str:
    try:
        data = Path(f"/proc/{pid}/environ").read_bytes()
        for item in data.split(b"\x00"):
            if item.startswith(key.encode() + b"="):
                return item.split(b"=", 1)[1].decode(errors="replace").strip()
    except OSError:
        pass
    return ""


def _guess_game_name_from_proc(executable: str) -> str:
    """Scan /proc for a process whose exe matches and read env vars."""
    exe_lower = Path(executable).name.lower()
    try:
        for entry in os.scandir("/proc"):
            if not entry.name.isdigit():
                continue
            try:
                proc_exe = Path(os.readlink(f"/proc/{entry.name}/exe")).name.lower()
                if proc_exe == exe_lower or proc_exe.startswith(exe_lower):
                    pid = int(entry.name)
                    for key in ("STEAM_GAME", "STEAM_APP_ID", "HEROIC_APP_NAME", "GAME_NAME"):
                        val = _proc_env(pid, key)
                        if val:
                            return val
            except OSError:
                pass
    except OSError:
        pass
    return ""


def derive_game_name(stem: str) -> tuple[str, str]:
    """
    MangoHud names CSV files like:  <executable>_YYYY-MM-DD_HH:MM:SS.csv
    Returns (game_name, executable).
    """
    # Strip trailing timestamp: _2025-01-15_14:22:01
    m = re.match(r"^(.+?)_\d{4}-\d{2}-\d{2}_\d{2}[:\-]\d{2}[:\-]\d{2}$", stem)
    executable = m.group(1) if m else stem

    # Try live /proc lookup first (works if game is still running)
    game_name = _guess_game_name_from_proc(executable)
    if not game_name:
        # Pretty-print the executable: "my-game-exe" → "My Game Exe"
        game_name = executable.replace("-", " ").replace("_", " ").title()

    return game_name, executable


def detect_launcher(executable: str, header_info: dict) -> str:
    driver = header_info.get("driver", "").lower()
    exe = executable.lower()
    if "steam" in exe or "proton" in driver:
        return "Steam"
    if "heroic" in exe:
        return "Heroic"
    if "lutris" in exe:
        return "Lutris"
    if "wine" in exe:
        return "Wine"
    return "Native"


# ---------------------------------------------------------------------------
# CSV parsing
# ---------------------------------------------------------------------------

def parse_mangohud_csv(path: Path) -> tuple[dict, list[dict]] | None:
    """
    Parse a MangoHud CSV file.  Returns (header_info, rows) or None on failure.

    MangoHud CSV layout:
      Line 1: header names  (os,gpu,cpu,kernel,driver,cpu-scheduler,cpufreq,…)
      Line 2: header values
      Line 3: column names  (fps,frametime,cpu_load,gpu_load,cpu_temp,…)
      Line 4+: data rows
    """
    try:
        lines = path.read_text(errors="replace").splitlines()
    except OSError:
        return None

    if len(lines) < 4:
        return None

    try:
        meta_keys   = [k.strip() for k in lines[0].split(",")]
        meta_vals   = [v.strip() for v in lines[1].split(",")]
        header_info = dict(zip(meta_keys, meta_vals))
    except Exception:
        header_info = {}

    # Find the actual data header row (contains "fps" column)
    data_start = None
    for i in range(2, min(6, len(lines))):
        if "fps" in lines[i].lower():
            data_start = i
            break
    if data_start is None:
        return None

    try:
        reader = csv.DictReader(lines[data_start:])
        rows = []
        for row in reader:
            try:
                rows.append({k.strip(): v.strip() for k, v in row.items() if k})
            except Exception:
                continue
    except Exception:
        return None

    return header_info, rows


def _safe_float(val: str, default: float = 0.0) -> float:
    try:
        return float(val)
    except (ValueError, TypeError):
        return default


# ---------------------------------------------------------------------------
# Ingest one CSV
# ---------------------------------------------------------------------------

def ingest_csv(conn: sqlite3.Connection, path: Path) -> bool:
    source_file = str(path)
    if already_ingested(conn, source_file):
        return False

    parsed = parse_mangohud_csv(path)
    if parsed is None:
        LOG.warning("Could not parse %s — skipping", path.name)
        return False

    header_info, rows = parsed
    if not rows:
        LOG.debug("Empty CSV %s — skipping", path.name)
        return False

    game_name, executable = derive_game_name(path.stem)
    launcher = detect_launcher(executable, header_info)

    # Build frame list
    frame_data = []
    fps_vals: list[float] = []
    ft_vals:  list[float] = []
    gpu_temps: list[float] = []
    vram_vals: list[float] = []
    cpu_loads: list[float] = []
    gpu_loads: list[float] = []
    ts_vals:  list[float] = []

    for row in rows:
        fps   = _safe_float(row.get("fps", ""))
        ft    = _safe_float(row.get("frametime", ""))
        cload = _safe_float(row.get("cpu_load", ""))
        gload = _safe_float(row.get("gpu_load", ""))
        ctemp = _safe_float(row.get("cpu_temp", ""))
        gtemp = _safe_float(row.get("gpu_temp", ""))
        vram  = _safe_float(row.get("vram_used", "0")) / 1024.0   # KiB → MiB
        ts    = _safe_float(row.get("time", "0"))

        if fps > 0:
            fps_vals.append(fps)
        if ft > 0:
            ft_vals.append(ft)
        if gtemp > 0:
            gpu_temps.append(gtemp)
        if vram > 0:
            vram_vals.append(vram)
        if cload > 0:
            cpu_loads.append(cload)
        if gload > 0:
            gpu_loads.append(gload)
        if ts > 0:
            ts_vals.append(ts)

        frame_data.append({
            "ts": ts, "fps": fps, "frametime": ft,
            "cpu_load": cload, "gpu_load": gload,
            "cpu_temp": ctemp, "gpu_temp": gtemp,
            "vram_mb": vram,
        })

    if not fps_vals:
        LOG.debug("No valid FPS data in %s", path.name)
        return False

    # Session stats
    avg_fps    = sum(fps_vals) / len(fps_vals)
    sorted_fps = sorted(fps_vals)
    n          = len(sorted_fps)
    p1_low     = sum(sorted_fps[: max(1, n // 100)]) / max(1, n // 100)
    p01_low    = sum(sorted_fps[: max(1, n // 1000)]) / max(1, n // 1000)

    # A "stutter" is a frame where frametime > 2× the median
    if ft_vals:
        median_ft = sorted(ft_vals)[len(ft_vals) // 2]
        stutter_count = sum(1 for v in ft_vals if v > median_ft * 2)
    else:
        stutter_count = 0

    peak_gpu_temp = max(gpu_temps) if gpu_temps else None
    peak_vram_mb  = max(vram_vals) if vram_vals else None
    avg_cpu_load  = sum(cpu_loads) / len(cpu_loads) if cpu_loads else None
    avg_gpu_load  = sum(gpu_loads) / len(gpu_loads) if gpu_loads else None

    # Timestamps — try to read from first/last ts column, fall back to mtime
    if ts_vals:
        started_at = int(path.stat().st_mtime - (ts_vals[-1] - ts_vals[0]))
        ended_at   = int(path.stat().st_mtime)
        duration_s = ts_vals[-1] - ts_vals[0] if len(ts_vals) > 1 else 0.0
    else:
        ended_at   = int(path.stat().st_mtime)
        duration_s = float(len(frame_data) / avg_fps) if avg_fps > 0 else 0.0
        started_at = ended_at - int(duration_s)

    now = int(time.time())

    with conn:
        cur = conn.execute(
            """
            INSERT OR IGNORE INTO sessions (
                game_name, executable, launcher, source_file,
                started_at, ended_at, duration_s,
                avg_fps, p1_low_fps, p01_low_fps, stutter_count,
                peak_gpu_temp, peak_vram_mb, avg_cpu_load, avg_gpu_load,
                gpu_name, cpu_name, kernel, driver, scheduler, ingested_at
            ) VALUES (
                ?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?
            )
            """,
            (
                game_name, executable, launcher, source_file,
                started_at, ended_at, duration_s,
                avg_fps, p1_low, p01_low, stutter_count,
                peak_gpu_temp, peak_vram_mb, avg_cpu_load, avg_gpu_load,
                header_info.get("gpu"), header_info.get("cpu"),
                header_info.get("kernel"), header_info.get("driver"),
                header_info.get("cpu-scheduler"),
                now,
            ),
        )
        session_id = cur.lastrowid

        if session_id and frame_data:
            # Insert frames in bulk (skip if very long session; store at most 36000 frames ~10 min @60fps)
            sample = frame_data if len(frame_data) <= 36000 else frame_data[::len(frame_data)//36000]
            conn.executemany(
                """
                INSERT INTO frames (session_id, ts, fps, frametime, cpu_load, gpu_load, cpu_temp, gpu_temp, vram_mb)
                VALUES (?,?,?,?,?,?,?,?,?)
                """,
                [
                    (session_id,
                     f["ts"], f["fps"], f["frametime"],
                     f["cpu_load"], f["gpu_load"],
                     f["cpu_temp"], f["gpu_temp"], f["vram_mb"])
                    for f in sample
                ],
            )

    LOG.info(
        "Ingested %s — %s  %.1f avg fps  1%% low %.1f  %d frames  %d stutters",
        path.name, game_name, avg_fps, p1_low, len(frame_data), stutter_count,
    )
    return True


# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

def scan(conn: sqlite3.Connection) -> int:
    """Scan SESSIONS_DIR for stable new CSVs. Returns count ingested."""
    ingested = 0
    now = time.time()
    try:
        for entry in sorted(SESSIONS_DIR.iterdir()):
            if entry.suffix.lower() != ".csv":
                continue
            try:
                age = now - entry.stat().st_mtime
            except OSError:
                continue
            if age < _MIN_FILE_AGE:
                continue  # still being written
            if ingest_csv(conn, entry):
                ingested += 1
    except OSError:
        pass
    return ingested


def main() -> None:
    logging.basicConfig(
        level=logging.INFO,
        format="%(name)s: %(levelname)s %(message)s",
        stream=sys.stderr,
    )

    ensure_mangohud_output()

    conn = open_db()
    force_scan = False

    def on_sighup(signum, frame):
        nonlocal force_scan
        LOG.info("SIGHUP — re-scanning immediately")
        force_scan = True

    signal.signal(signal.SIGHUP, on_sighup)

    LOG.info("Started — watching %s", SESSIONS_DIR)

    while True:
        try:
            n = scan(conn)
            if n:
                LOG.info("Ingested %d new session(s)", n)
        except Exception as exc:
            LOG.exception("Scan error: %s", exc)

        force_scan = False
        # Sleep in small chunks so SIGHUP wakes us promptly
        for _ in range(_SCAN_INTERVAL * 2):
            if force_scan:
                break
            time.sleep(0.5)


if __name__ == "__main__":
    main()
