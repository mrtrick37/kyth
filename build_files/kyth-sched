#!/usr/bin/env python3
"""
kyth-sched — automatic sched-ext profile switcher for KythOS.

Monitors GameMode and /proc for active gaming sessions and switches the
BPF scheduler between a gaming profile (scx_lavd) and a desktop profile
(scx_bpfland).  Also integrates with kyth-performance-mode to wire EPP
and compositor tweaks into the same trigger.

Config: ~/.config/kyth/sched-profiles.toml  (user)
        /etc/kyth/sched-profiles.toml        (system fallback)

Status: $XDG_RUNTIME_DIR/kyth-sched-status.json  (read by System Hub)

Signals:
  SIGHUP  — reload config
  SIGUSR1 — force gaming profile (manual override)
  SIGUSR2 — force desktop profile (clear override)
"""
from __future__ import annotations

import json
import logging
import os
import signal
import subprocess
import sys
import time
import tomllib
from pathlib import Path

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

LOG = logging.getLogger("kyth-sched")

_UID = os.getuid()
_RUNTIME_DIR = Path(os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{_UID}"))
STATUS_FILE = _RUNTIME_DIR / "kyth-sched-status.json"

DEFAULT_CONFIG: dict = {
    "desktop_scheduler":  "scx_bpfland",
    "gaming_scheduler":   "scx_lavd",
    "poll_interval":      5,
    "integrate_perf_mode": True,   # also call kyth-performance-mode on switch
}

# Process names that indicate a gaming session even without GameMode
GAMING_PROCS = frozenset({
    "steam", "steam-native", "steamwebhelper", "steamwebhelper.sh",
    "gamescope", "heroic", "lutris", "bottles",
    "wine", "wine64", "wineserver", "wine-preloader",
    "pressure-vessel-wrap",
})


# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

def load_config() -> dict:
    candidates = [
        Path.home() / ".config/kyth/sched-profiles.toml",
        Path("/etc/kyth/sched-profiles.toml"),
    ]
    for p in candidates:
        if p.exists():
            try:
                with open(p, "rb") as f:
                    data = tomllib.load(f)
                return {**DEFAULT_CONFIG, **data.get("scheduler", data)}
            except Exception as exc:
                LOG.warning("Could not read config %s: %s", p, exc)
    return DEFAULT_CONFIG.copy()


# ---------------------------------------------------------------------------
# Scheduler control
# ---------------------------------------------------------------------------

def _run(*cmd: str, timeout: int = 5) -> tuple[bool, str]:
    try:
        r = subprocess.run(
            list(cmd),
            capture_output=True, text=True,
            timeout=timeout, check=False,
        )
        return r.returncode == 0, r.stdout.strip()
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False, ""


def current_scheduler() -> str:
    """Read active scheduler from scx_loader config or sysfs."""
    # Try sysfs first — most reliable
    state_path = Path("/sys/kernel/sched_ext/root/ops")
    if state_path.exists():
        try:
            return state_path.read_text().strip()
        except OSError:
            pass
    # Fall back to kyth-scx status output
    ok, out = _run("kyth-scx", "status")
    if ok:
        for line in out.splitlines():
            if line.startswith("Configured scheduler:"):
                sched = line.split(":", 1)[-1].strip()
                if sched:
                    return sched
    return "unknown"


def set_scheduler(name: str) -> bool:
    """Switch scheduler via kyth-scx (NOPASSWD sudo)."""
    ok, out = _run("sudo", "-n", "/usr/bin/kyth-scx", "set", name)
    if ok:
        LOG.info("Scheduler → %s", name)
    else:
        LOG.warning("kyth-scx set %s failed — scx_loader may not be running", name)
    return ok


def available_schedulers() -> list[str]:
    ok, out = _run("kyth-scx", "list")
    if ok and out:
        return [l.strip() for l in out.splitlines() if l.strip()]
    # Fall back to scanning /usr/bin
    return sorted(
        p.name for p in Path("/usr/bin").glob("scx_*")
        if p.is_file() and p.name != "scx_loader"
    )


# ---------------------------------------------------------------------------
# Gaming detection
# ---------------------------------------------------------------------------

def gamemode_active() -> bool:
    """Ask GameMode daemon whether any game is registered."""
    ok, out = _run(
        "busctl", "--user", "call",
        "com.feralinteractive.GameMode",
        "/com/feralinteractive/GameMode",
        "com.feralinteractive.GameMode",
        "QueryStatus", "i", "0",
        timeout=3,
    )
    if ok and out:
        try:
            return int(out.split()[-1]) > 0
        except (ValueError, IndexError):
            pass
    return False


def proc_gaming_active() -> bool:
    """Fallback: scan /proc for known gaming executables."""
    try:
        for entry in os.scandir("/proc"):
            if not entry.name.isdigit():
                continue
            try:
                exe = os.readlink(f"/proc/{entry.name}/exe")
                if Path(exe).name.lower() in GAMING_PROCS:
                    return True
            except OSError:
                pass
    except OSError:
        pass
    return False


def gamescope_session_active() -> bool:
    return (_RUNTIME_DIR / "gamescope-session.lock").exists()


def is_gaming() -> bool:
    return gamescope_session_active() or gamemode_active() or proc_gaming_active()


# ---------------------------------------------------------------------------
# Performance mode integration
# ---------------------------------------------------------------------------

def perf_mode(mode: str) -> None:
    """Call kyth-performance-mode non-blocking; failures are non-fatal."""
    try:
        subprocess.Popen(
            ["/usr/bin/kyth-performance-mode", mode],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    except FileNotFoundError:
        pass


# ---------------------------------------------------------------------------
# Status reporting
# ---------------------------------------------------------------------------

def write_status(profile: str, scheduler: str, gaming: bool, override: bool) -> None:
    STATUS_FILE.parent.mkdir(parents=True, exist_ok=True)
    try:
        STATUS_FILE.write_text(json.dumps({
            "profile":      profile,
            "scheduler":    scheduler,
            "gaming_active": gaming,
            "manual_override": override,
            "ts":           int(time.time()),
        }))
    except OSError as exc:
        LOG.debug("Could not write status: %s", exc)


# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

def main() -> None:
    logging.basicConfig(
        level=logging.INFO,
        format="%(name)s: %(levelname)s %(message)s",
        stream=sys.stderr,
    )

    cfg = load_config()
    profile = "desktop"
    gaming_prev = False
    manual_override: str | None = None   # "gaming" | "desktop" | None

    def reload_config(signum, frame):
        nonlocal cfg
        LOG.info("Reloading config (SIGHUP)")
        cfg = load_config()

    def force_gaming(signum, frame):
        nonlocal manual_override
        LOG.info("Manual override → gaming (SIGUSR1)")
        manual_override = "gaming"

    def force_desktop(signum, frame):
        nonlocal manual_override
        LOG.info("Manual override cleared (SIGUSR2)")
        manual_override = None

    signal.signal(signal.SIGHUP,  reload_config)
    signal.signal(signal.SIGUSR1, force_gaming)
    signal.signal(signal.SIGUSR2, force_desktop)

    # Apply initial desktop profile
    set_scheduler(cfg["desktop_scheduler"])
    if cfg.get("integrate_perf_mode"):
        perf_mode("balanced")

    LOG.info(
        "Started — desktop=%s  gaming=%s  poll=%ds",
        cfg["desktop_scheduler"], cfg["gaming_scheduler"], cfg["poll_interval"],
    )

    while True:
        try:
            effective = manual_override or ("gaming" if is_gaming() else "desktop")
            gaming_now = (effective == "gaming")

            if gaming_now != gaming_prev:
                if gaming_now:
                    set_scheduler(cfg["gaming_scheduler"])
                    if cfg.get("integrate_perf_mode"):
                        perf_mode("gaming")
                    profile = "gaming"
                    LOG.info("→ gaming profile (%s)", cfg["gaming_scheduler"])
                else:
                    set_scheduler(cfg["desktop_scheduler"])
                    if cfg.get("integrate_perf_mode"):
                        perf_mode("restore")
                    profile = "desktop"
                    LOG.info("→ desktop profile (%s)", cfg["desktop_scheduler"])
                gaming_prev = gaming_now

            write_status(profile, current_scheduler(), gaming_now, manual_override is not None)

        except Exception as exc:
            LOG.exception("Poll error: %s", exc)

        time.sleep(cfg["poll_interval"])


if __name__ == "__main__":
    main()
