#!/usr/bin/env python3
"""Lock the Plasma session when a trusted KDE Connect device leaves."""

from __future__ import annotations

import json
import os
import shutil
import signal
import subprocess
import time
from pathlib import Path


CONFIG_PATH = Path(
    os.environ.get(
        "KYTH_DYNAMIC_LOCK_CONFIG",
        str(Path.home() / ".config" / "kyth-dynamic-lock.json"),
    )
)
POLL_SECONDS = 5
_running = True


def _stop(_signum: int, _frame: object) -> None:
    global _running
    _running = False


def _load_config() -> dict[str, object]:
    try:
        data = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    return data


def _available_device_ids() -> set[str] | None:
    binary = shutil.which("kdeconnect-cli")
    if binary is None:
        return None
    try:
        result = subprocess.run(
            [binary, "--list-available", "--id-only"],
            capture_output=True,
            text=True,
            timeout=12,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if result.returncode != 0:
        return None
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def _lock_session() -> bool:
    commands = (
        ["qdbus6", "org.freedesktop.ScreenSaver", "/ScreenSaver", "Lock"],
        ["qdbus-qt6", "org.freedesktop.ScreenSaver", "/ScreenSaver", "Lock"],
        ["qdbus", "org.freedesktop.ScreenSaver", "/ScreenSaver", "Lock"],
        ["loginctl", "lock-session"],
    )
    for cmd in commands:
        binary = shutil.which(cmd[0])
        if binary is None:
            continue
        try:
            result = subprocess.run(
                [binary, *cmd[1:]],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=10,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired):
            continue
        if result.returncode == 0:
            return True
    return False


def monitor() -> int:
    device_id = ""
    armed = False
    missing_since: float | None = None

    while _running:
        config = _load_config()
        configured_id = str(config.get("device_id") or "").strip()
        enabled = config.get("enabled") is True and bool(configured_id)
        try:
            grace_seconds = max(15, min(600, int(config.get("grace_seconds", 60))))
        except (TypeError, ValueError):
            grace_seconds = 60

        if not enabled:
            device_id = ""
            armed = False
            missing_since = None
            time.sleep(POLL_SECONDS)
            continue

        if configured_id != device_id:
            device_id = configured_id
            armed = False
            missing_since = None

        available = _available_device_ids()
        if available is None:
            # A broken KDE Connect query should never be treated as the phone leaving.
            missing_since = None
        elif device_id in available:
            armed = True
            missing_since = None
        elif armed:
            now = time.monotonic()
            if missing_since is None:
                missing_since = now
            elif now - missing_since >= grace_seconds:
                if _lock_session():
                    # Require the trusted device to return before another lock attempt.
                    armed = False
                    missing_since = None

        time.sleep(POLL_SECONDS)

    return 0


def main() -> int:
    signal.signal(signal.SIGINT, _stop)
    signal.signal(signal.SIGTERM, _stop)
    return monitor()


if __name__ == "__main__":
    raise SystemExit(main())
