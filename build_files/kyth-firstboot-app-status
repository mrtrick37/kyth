#!/usr/bin/env bash
# User-session notifier for default app setup progress.

set -uo pipefail

STAMP_DIR="${HOME}/.local/share/kyth"
STAMP="${STAMP_DIR}/firstboot-app-status-v1"
STATUS="${STAMP_DIR}/first-run-apps.status"
DEFAULT_DONE="/var/lib/kyth/default-flatpaks-v5-done"

have() { command -v "$1" >/dev/null 2>&1; }

if grep -qw 'kyth.live' /proc/cmdline 2>/dev/null; then
    exit 0
fi

notify() {
    local title="$1"
    local body="$2"
    if have notify-send; then
        notify-send --app-name="KythOS" "$title" "$body" >/dev/null 2>&1 || true
    elif have kdialog; then
        kdialog --title "$title" --passivepopup "$body" 12 >/dev/null 2>&1 || true
    fi
}

write_status() {
    local state="$1"
    local message="$2"
    mkdir -p "${STAMP_DIR}"
    {
        printf 'state=%q\n' "${state}"
        printf 'message=%q\n' "${message}"
        printf 'updated=%q\n' "$(date -Is 2>/dev/null || date)"
    } > "${STATUS}" 2>/dev/null || true
}

flatpak_ok() {
    flatpak info "$1" >/dev/null 2>&1
}

missing_apps() {
    local missing=()
    for app in \
        com.valvesoftware.Steam \
        net.lutris.Lutris \
        com.heroicgameslauncher.hgl \
        com.usebottles.bottles \
        com.github.mtkennerly.ludusavi; do
        flatpak_ok "$app" || missing+=("$app")
    done
    printf '%s\n' "${missing[@]}"
}

mkdir -p "${STAMP_DIR}"

if [[ "${1:-}" != "--force" && -f "${STAMP}" && -f "${DEFAULT_DONE}" ]]; then
    exit 0
fi

sleep "${KYTH_APP_STATUS_DELAY:-20}"

if ! have flatpak; then
    write_status "needs_attention" "Flatpak is not available. Open System Hub > Repair for details."
    exit 2
fi

missing="$(missing_apps)"
if [[ -z "${missing}" ]]; then
    write_status "ready" "Steam, launchers, Bottles, and save backup tools are installed."
    if [[ "${1:-}" == "--force" || "${KYTH_APP_STATUS_NOTIFY_READY:-0}" == "1" ]]; then
        notify "KythOS apps are ready" "Steam, launchers, Bottles, and save backup tools are installed."
    fi
    touch "${STAMP}"
    exit 0
fi

service_state="unknown"
if have systemctl; then
    service_state="$(systemctl is-active kyth-default-flatpaks.service 2>/dev/null || true)"
fi

case "${service_state}" in
    active|activating)
        write_status "setting_up" "Game launchers and migration tools are installing in the background."
        ;;
    failed)
        write_status "failed" "Some default apps are missing. Open System Hub > Repair and retry Game Apps."
        ;;
    *)
        if have sudo && sudo -n systemctl start kyth-default-flatpaks.service >/dev/null 2>&1; then
            write_status "setting_up" "Game launchers and migration tools have started installing in the background."
        else
            write_status "needs_attention" "Some default apps are missing. Connect to the network, then open System Hub > Repair and retry Game Apps."
        fi
        ;;
esac

exit 1
