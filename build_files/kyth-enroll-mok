#!/bin/bash
# kyth-enroll-mok — first-boot KythOS Secure Boot MOK enrollment.
#
# Runs once at boot. If Secure Boot is active and the KythOS key is not yet
# enrolled, stages it via mokutil. On the next reboot, UEFI's MokManager will
# present a confirmation screen — enter the password "kyth" to complete
# enrollment. Once enrolled the kernel and its signed vmlinuz are trusted.
#
# The flag file is written only after enrollment is already complete or has
# been staged. If Secure Boot is disabled, keep the service eligible for a
# later boot and direct existing users to the manual pre-enrollment recipe.

set -euo pipefail

FLAG="${KYTH_MOK_FLAG:-/var/lib/kyth/mok-enrolled}"
CERT_PEM="${KYTH_MOK_CERT_PEM:-/usr/share/kyth/secureboot/kyth-secureboot.cer}"
CERT_DER="${KYTH_MOK_CERT_DER:-/usr/share/kyth/secureboot/kyth-secureboot.der}"
MOKUTIL="${KYTH_MOKUTIL:-mokutil}"

mkdir -p "$(dirname "${FLAG}")"

if [[ ! -f "${CERT_PEM}" && ! -f "${CERT_DER}" ]]; then
    echo "kyth-enroll-mok: cert not found — image built without Secure Boot support"
    touch "${FLAG}"
    exit 0
fi

if [[ ! -f "${CERT_DER}" ]]; then
    echo "kyth-enroll-mok: DER cert not found — converting PEM cert for mokutil"
    CERT_DER="$(dirname "${FLAG}")/kyth-secureboot.der"
    openssl x509 -in "${CERT_PEM}" -outform DER -out "${CERT_DER}"
fi

# Check if Secure Boot is active in the firmware
SB_STATE=$("${MOKUTIL}" --sb-state 2>/dev/null || true)
if ! echo "${SB_STATE}" | grep -q "SecureBoot enabled"; then
    echo "kyth-enroll-mok: Secure Boot not enabled — automatic enrollment deferred"
    echo "kyth-enroll-mok: run 'ujust enroll-secureboot' before enabling Secure Boot"
    echo "kyth-enroll-mok: leaving service active so enrollment can be staged later"
    exit 0
fi

# Check if our key is already enrolled
if "${MOKUTIL}" --list-enrolled 2>/dev/null | grep -q "KythOS Secure Boot"; then
    echo "kyth-enroll-mok: KythOS Secure Boot key already enrolled"
    touch "${FLAG}"
    exit 0
fi

# Stage the enrollment — user confirms with password "kyth" in MokManager
echo "kyth-enroll-mok: staging Secure Boot MOK enrollment"
if echo "kyth" | "${MOKUTIL}" --import "${CERT_DER}" --stdin-passwd; then
    echo "kyth-enroll-mok: enrollment staged — reboot and enter password 'kyth' at the MokManager screen"
else
    echo "kyth-enroll-mok: mokutil import failed (non-fatal)" >&2
fi

touch "${FLAG}"
