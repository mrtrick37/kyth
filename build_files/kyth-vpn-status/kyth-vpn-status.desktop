[Desktop Entry]
Version=1.0
Name=VPN Status
Comment=Show VPN connection status in the system tray
Exec=/usr/bin/kyth-vpn-status
Icon=network-vpn
Terminal=false
Type=Application
Categories=Network;TrayIcon;
Keywords=vpn;status;tray;openconnect;globalprotect;
NoDisplay=true
OnlyShowIn=KDE;
X-KDE-autostart-after=panel
