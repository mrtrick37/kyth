#!/usr/bin/env python3
"""KythOS VPN status tray helper."""

import os
import subprocess
import sys

from PyQt6.QtCore import QTimer
from PyQt6.QtGui import QAction, QIcon
from PyQt6.QtWidgets import QApplication, QMenu, QSystemTrayIcon


def _run(args: list[str]) -> str:
    try:
        return subprocess.check_output(
            args,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=2,
        )
    except Exception:
        return ""


def _openconnect_running() -> bool:
    return bool(_run(["pgrep", "-x", "openconnect"]).strip())


def _vpn_has_address() -> bool:
    output = _run(["ip", "-o", "addr", "show"])
    for line in output.splitlines():
        if " tun" in line or " vpn" in line:
            if " inet " in line or " inet6 " in line:
                return True
    return False


def _launch_client() -> None:
    subprocess.Popen(
        ["/usr/bin/kyth-vpn-connect"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


class VpnTray:
    def __init__(self) -> None:
        self._tray = QSystemTrayIcon()
        self._tray.setIcon(QIcon.fromTheme("network-vpn"))
        self._tray.activated.connect(self._on_activated)

        self._menu = QMenu()
        self._status_action = QAction("VPN: checking...")
        self._status_action.setEnabled(False)
        self._open_action = QAction("Open VPN Connect")
        self._open_action.triggered.connect(_launch_client)
        self._quit_action = QAction("Quit Status Helper")
        self._quit_action.triggered.connect(QApplication.quit)
        self._menu.addAction(self._status_action)
        self._menu.addSeparator()
        self._menu.addAction(self._open_action)
        self._menu.addAction(self._quit_action)
        self._tray.setContextMenu(self._menu)

        self._timer = QTimer()
        self._timer.setInterval(3000)
        self._timer.timeout.connect(self._update)
        self._timer.start()
        self._update()
        self._tray.show()

    def _on_activated(self, reason) -> None:
        if reason in (
            QSystemTrayIcon.ActivationReason.Trigger,
            QSystemTrayIcon.ActivationReason.DoubleClick,
        ):
            _launch_client()

    def _update(self) -> None:
        running = _openconnect_running()
        connected = running and _vpn_has_address()
        if connected:
            icon = "network-vpn"
            text = "VPN: connected"
            tooltip = "VPN connected"
        elif running:
            icon = "network-vpn-acquiring"
            text = "VPN: connecting"
            tooltip = "VPN connecting"
        else:
            icon = "network-vpn-disconnected"
            text = "VPN: disconnected"
            tooltip = "VPN disconnected"

        qicon = QIcon.fromTheme(icon)
        if qicon.isNull():
            qicon = QIcon.fromTheme("network-vpn")
        self._tray.setIcon(qicon)
        self._tray.setToolTip(tooltip)
        self._status_action.setText(text)


def main() -> None:
    os.environ.setdefault("QT_QPA_PLATFORMTHEME", "kde")
    app = QApplication(sys.argv)
    app.setApplicationName("kyth-vpn-status")
    app.setQuitOnLastWindowClosed(False)
    VpnTray()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
