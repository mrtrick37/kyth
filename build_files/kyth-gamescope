#!/usr/bin/env bash
set -euo pipefail

show_help() {
    cat <<'HELPEOF'
Usage: kyth-gamescope [preset] [options] -- <command> [args...]

Presets:
  balanced      Gamescope with Steam overlay/input support.
  quality       balanced + MangoHud + adaptive sync + FSR-friendly defaults.
  hdr           quality + HDR metadata path.
  sharp         quality + vkBasalt CAS sharpening.
  latency       balanced + adaptive sync + FPS cap if supplied.

Options:
  --hdr                 Enable Gamescope HDR path.
  --vrr                 Enable adaptive sync / VRR.
  --mangohud            Enable MangoHud.
  --vkbasalt            Enable vkBasalt with the system CAS config.
  --gamemode            Wrap the command with gamemoderun.
  --fsr                 Enable Gamescope FSR upscaling.
  --fps <n>             Set Gamescope frame-rate limit.
  --nested <WxH>        Set nested game resolution, e.g. 1920x1080.
  --output <WxH>        Set output resolution, e.g. 2560x1440.
  -h, --help            Show this help.

Steam examples:
  kyth-gamescope quality -- %command%
  kyth-gamescope hdr --fps 120 -- %command%
  kyth-gamescope sharp --fsr --nested 1920x1080 --output 2560x1440 -- %command%
HELPEOF
}

preset="balanced"
hdr=0
vrr=0
mangohud=0
vkbasalt=0
gamemode=0
fsr=0
fps=""
nested=""
output=""

if [[ $# -gt 0 && "$1" != --* && "$1" != "--" ]]; then
    preset="$1"
    shift
fi

case "$preset" in
    balanced|standard)
        ;;
    quality)
        mangohud=1
        vrr=1
        ;;
    hdr)
        hdr=1
        vrr=1
        mangohud=1
        ;;
    sharp)
        mangohud=1
        vkbasalt=1
        vrr=1
        ;;
    latency)
        vrr=1
        ;;
    -h|--help)
        show_help
        exit 0
        ;;
    *)
        echo "Unknown preset: ${preset}" >&2
        show_help >&2
        exit 1
        ;;
esac

while [[ $# -gt 0 ]]; do
    case "$1" in
        --hdr) hdr=1; shift ;;
        --vrr|--adaptive-sync) vrr=1; shift ;;
        --mangohud) mangohud=1; shift ;;
        --vkbasalt) vkbasalt=1; shift ;;
        --gamemode) gamemode=1; shift ;;
        --fsr) fsr=1; shift ;;
        --fps)
            [[ $# -ge 2 ]] || { echo "Missing value for --fps" >&2; exit 1; }
            fps="$2"
            shift 2
            ;;
        --nested)
            [[ $# -ge 2 ]] || { echo "Missing value for --nested" >&2; exit 1; }
            nested="$2"
            shift 2
            ;;
        --output)
            [[ $# -ge 2 ]] || { echo "Missing value for --output" >&2; exit 1; }
            output="$2"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -eq 0 ]]; then
    echo "No command supplied." >&2
    show_help >&2
    exit 1
fi

if ! command -v gamescope >/dev/null 2>&1; then
    echo "gamescope is not installed." >&2
    exit 127
fi

parse_res() {
    local value=$1
    local width height
    width="${value%x*}"
    height="${value#*x}"
    [[ "$width" =~ ^[0-9]+$ && "$height" =~ ^[0-9]+$ ]] || return 1
    printf '%s %s\n' "$width" "$height"
}

gs=(gamescope -e)
if [[ "$hdr" -eq 1 ]]; then
    gs+=(--hdr-enabled)
fi
if [[ "$vrr" -eq 1 ]]; then
    gs+=(--adaptive-sync)
fi
if [[ "$fsr" -eq 1 ]]; then
    gs+=(-F fsr)
fi
if [[ -n "$fps" ]]; then
    [[ "$fps" =~ ^[0-9]+$ ]] || { echo "--fps expects a number" >&2; exit 1; }
    gs+=(-r "$fps")
fi
if [[ -n "$nested" ]]; then
    read -r width height < <(parse_res "$nested") || {
        echo "--nested expects WxH, e.g. 1920x1080" >&2
        exit 1
    }
    gs+=(-w "$width" -h "$height")
fi
if [[ -n "$output" ]]; then
    read -r width height < <(parse_res "$output") || {
        echo "--output expects WxH, e.g. 2560x1440" >&2
        exit 1
    }
    gs+=(-W "$width" -H "$height")
fi

env_args=()
if [[ "$mangohud" -eq 1 ]]; then
    env_args+=(MANGOHUD=1)
fi
if [[ "$vkbasalt" -eq 1 ]]; then
    env_args+=(ENABLE_VKBASALT=1)
fi

cmd=("$@")
if [[ "$gamemode" -eq 1 ]] && command -v gamemoderun >/dev/null 2>&1; then
    cmd=(gamemoderun "${cmd[@]}")
fi

exec env "${env_args[@]}" "${gs[@]}" -- "${cmd[@]}"
