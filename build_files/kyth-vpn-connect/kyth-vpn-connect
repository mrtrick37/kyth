#!/usr/bin/env python3
"""kyth-vpn-connect — Generic openconnect VPN launcher for KythOS.

Workaround for KDE bug #485093: the plasma-nm openconnect plugin crashes kded6
with SIGSEGV in OpenconnectAuthWorkerThread when authenticating GlobalProtect.
This app runs openconnect directly via sudo, bypassing the broken plugin.
"""

import configparser
import os
import subprocess
import sys
from pathlib import Path

from PyQt6.QtCore import Qt, QThread, pyqtSignal
from PyQt6.QtGui import QFont
from PyQt6.QtWidgets import (
    QApplication,
    QComboBox,
    QFormLayout,
    QFrame,
    QGroupBox,
    QHBoxLayout,
    QLabel,
    QLineEdit,
    QMainWindow,
    QPushButton,
    QTextEdit,
    QVBoxLayout,
    QWidget,
)

_CONFIG_PATH = Path.home() / ".config" / "kyth-vpn-connect"

_PROTOCOLS = ["gp", "anyconnect", "pulse", "nc", "f5", "fortinet", "array"]
_OS_OPTIONS = ["win", "linux", "mac"]


def _load_config() -> configparser.ConfigParser:
    cfg = configparser.ConfigParser()
    if _CONFIG_PATH.exists():
        cfg.read(_CONFIG_PATH)
    return cfg


def _save_config(gateway: str, protocol: str, os_emul: str, username: str) -> None:
    cfg = configparser.ConfigParser()
    cfg["vpn"] = {
        "gateway": gateway,
        "protocol": protocol,
        "os": os_emul,
        "username": username,
    }
    _CONFIG_PATH.write_text(cfg.write.__func__(cfg) or "")
    # Use proper write
    with open(_CONFIG_PATH, "w") as f:
        cfg.write(f)


class _VpnWorker(QThread):
    line = pyqtSignal(str)
    done = pyqtSignal(int)

    def __init__(self, cmd: list[str], password: str = ""):
        super().__init__()
        self._cmd = cmd
        self._password = password
        self._proc: subprocess.Popen | None = None

    def run(self) -> None:
        env = os.environ.copy()
        env.setdefault("SUDO_ASKPASS", "/usr/bin/ksshaskpass")
        stdin_pipe = subprocess.PIPE if self._password else subprocess.DEVNULL
        try:
            self._proc = subprocess.Popen(
                self._cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                stdin=stdin_pipe,
                text=True,
                bufsize=1,
                env=env,
                cwd="/tmp",
            )
            if self._password and self._proc.stdin:
                self._proc.stdin.write(self._password + "\n")
                self._proc.stdin.close()
            assert self._proc.stdout
            for ln in self._proc.stdout:
                self.line.emit(ln.rstrip())
            self._proc.wait()
            self.done.emit(self._proc.returncode)
        except Exception as exc:
            self.line.emit(f"Error: {exc}")
            self.done.emit(1)

    def stop(self) -> None:
        if self._proc and self._proc.poll() is None:
            self._proc.terminate()


class MainWindow(QMainWindow):
    def __init__(self) -> None:
        super().__init__()
        self._worker: _VpnWorker | None = None
        self.setWindowTitle("VPN Connect")
        self.setMinimumSize(560, 560)
        self._build_ui()
        self._load_saved_config()

    def _build_ui(self) -> None:
        root = QWidget()
        self.setCentralWidget(root)
        layout = QVBoxLayout(root)
        layout.setSpacing(10)
        layout.setContentsMargins(20, 20, 20, 20)

        title = QLabel("VPN Connect")
        f = QFont()
        f.setPointSize(15)
        f.setBold(True)
        title.setFont(f)
        layout.addWidget(title)

        # Configuration group
        config_group = QGroupBox("Connection Settings")
        form = QFormLayout(config_group)
        form.setRowWrapPolicy(QFormLayout.RowWrapPolicy.WrapLongRows)

        self._gateway = QLineEdit()
        self._gateway.setPlaceholderText("e.g. vpn.example.com")
        form.addRow("Gateway:", self._gateway)

        self._protocol = QComboBox()
        self._protocol.addItems(_PROTOCOLS)
        form.addRow("Protocol:", self._protocol)

        self._os_emul = QComboBox()
        self._os_emul.addItems(_OS_OPTIONS)
        form.addRow("OS emulation:", self._os_emul)

        self._username = QLineEdit()
        self._username.setPlaceholderText("optional")
        form.addRow("Username:", self._username)

        self._password = QLineEdit()
        self._password.setEchoMode(QLineEdit.EchoMode.Password)
        self._password.setPlaceholderText("optional — leave blank for interactive/SSO auth")
        form.addRow("Password:", self._password)

        layout.addWidget(config_group)

        sep = QFrame()
        sep.setFrameShape(QFrame.Shape.HLine)
        sep.setFrameShadow(QFrame.Shadow.Sunken)
        layout.addWidget(sep)

        self._status = QLabel("● Disconnected")
        self._status.setStyleSheet("color: palette(mid); font-weight: bold;")
        layout.addWidget(self._status)

        row = QHBoxLayout()
        self._connect_btn = QPushButton("Connect")
        self._connect_btn.setMinimumHeight(34)
        self._connect_btn.clicked.connect(self._on_connect)
        self._disconnect_btn = QPushButton("Disconnect")
        self._disconnect_btn.setMinimumHeight(34)
        self._disconnect_btn.setEnabled(False)
        self._disconnect_btn.clicked.connect(self._on_disconnect)
        row.addWidget(self._connect_btn)
        row.addWidget(self._disconnect_btn)
        layout.addLayout(row)

        self._log = QTextEdit()
        self._log.setReadOnly(True)
        self._log.setFont(QFont("monospace", 9))
        layout.addWidget(self._log)

    def _load_saved_config(self) -> None:
        cfg = _load_config()
        if "vpn" not in cfg:
            return
        v = cfg["vpn"]
        self._gateway.setText(v.get("gateway", ""))
        proto = v.get("protocol", "gp")
        idx = self._protocol.findText(proto)
        if idx >= 0:
            self._protocol.setCurrentIndex(idx)
        os_val = v.get("os", "win")
        idx = self._os_emul.findText(os_val)
        if idx >= 0:
            self._os_emul.setCurrentIndex(idx)
        self._username.setText(v.get("username", ""))

    def _on_connect(self) -> None:
        gateway = self._gateway.text().strip()
        if not gateway:
            self._log.append("[Error: Gateway is required]")
            return

        protocol = self._protocol.currentText()
        os_emul = self._os_emul.currentText()
        username = self._username.text().strip()
        password = self._password.text()

        _save_config(gateway, protocol, os_emul, username)

        self._log.clear()
        self._set_status("connecting")
        self._connect_btn.setEnabled(False)
        self._disconnect_btn.setEnabled(True)
        # Lock config fields while connected
        for w in (self._gateway, self._protocol, self._os_emul, self._username, self._password):
            w.setEnabled(False)

        cmd = [
            "sudo", "-E", "-A",
            "/usr/bin/openconnect",
            "--protocol", protocol,
            "--os", os_emul,
        ]
        if username:
            cmd += ["--user", username]
        if password:
            cmd += ["--passwd-on-stdin"]
        cmd.append(gateway)

        self._worker = _VpnWorker(cmd, password)
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_done)
        self._worker.start()

    def _on_disconnect(self) -> None:
        if self._worker:
            self._worker.stop()

    def _on_line(self, line: str) -> None:
        self._log.append(line)
        sb = self._log.verticalScrollBar()
        sb.setValue(sb.maximum())
        lo = line.lower()
        if "connected as" in lo or "established dtls" in lo or "established cstp" in lo:
            self._set_status("connected")

    def _on_done(self, code: int) -> None:
        self._set_status("disconnected")
        self._connect_btn.setEnabled(True)
        self._disconnect_btn.setEnabled(False)
        for w in (self._gateway, self._protocol, self._os_emul, self._username, self._password):
            w.setEnabled(True)
        self._log.append(f"\n[openconnect exited: code {code}]")
        self._worker = None

    def _set_status(self, state: str) -> None:
        if state == "connected":
            self._status.setText("● Connected")
            self._status.setStyleSheet("color: #4caf50; font-weight: bold;")
        elif state == "connecting":
            self._status.setText("● Connecting…")
            self._status.setStyleSheet("color: #ff9800; font-weight: bold;")
        else:
            self._status.setText("● Disconnected")
            self._status.setStyleSheet("color: palette(mid); font-weight: bold;")

    def closeEvent(self, event) -> None:  # type: ignore[override]
        if self._worker and self._worker.isRunning():
            self._worker.stop()
            self._worker.wait(3000)
        event.accept()


def main() -> None:
    app = QApplication(sys.argv)
    app.setApplicationName("kyth-vpn-connect")
    win = MainWindow()
    win.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
