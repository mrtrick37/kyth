#!/usr/bin/env bash
set -euo pipefail

out_dir="${1:-${HOME}/Documents/KythOS}"
mkdir -p "${out_dir}"
ts="$(date +%Y%m%d-%H%M%S)"
out="${out_dir}/kyth-session-snapshot-${ts}.txt"

section() {
    printf '\n== %s ==\n' "$1" >> "${out}"
}

run() {
    printf '$ %s\n' "$*" >> "${out}"
    "$@" >> "${out}" 2>&1 || true
}

{
    echo "KythOS Session Snapshot"
    echo "Generated: $(date -Is)"
    echo "User: ${USER:-unknown}"
    echo "Host: $(hostname 2>/dev/null || echo unknown)"
} > "${out}"

section "System"
run cat /etc/os-release
run uname -a
run bootc status

section "Desktop"
run xdg-user-dir
run xdg-mime query default application/x-ms-dos-executable
run xdg-mime query default application/x-msi

section "Installed Flatpaks"
run flatpak list --app --columns=application,name,version,branch

section "Gaming Paths"
for path in \
    "${HOME}/.local/share/Steam/steamapps" \
    "${HOME}/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps" \
    "${HOME}/Games" \
    "${HOME}/Applications"; do
    if [[ -e "${path}" ]]; then
        printf '%s\n' "${path}" >> "${out}"
    fi
done

section "KythOS Checks"
for cmd in kyth-controller-check kyth-resume-check kyth-nvidia-status; do
    if command -v "${cmd}" >/dev/null 2>&1; then
        run "${cmd}"
    fi
done

section "Restore Notes"
cat >> "${out}" <<'EOF'
- Reinstall Flatpaks with: flatpak install flathub APP_ID
- Keep source code, saves, and documents in /home or synced storage.
- System image changes are handled through KythOS updates and bootc rollback.
- Do not paste this file publicly without reviewing paths and usernames.
EOF

echo "${out}"
