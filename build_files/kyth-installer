.steps{flex:1;padding:0 10px}
.step{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;margin-bottom:2px}
.step-num{width:24px;height:24px;border-radius:50%;background:var(--surface2);border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--muted);flex-shrink:0;transition:all .2s}
.step-label{font-size:13px;color:var(--muted);font-weight:500;transition:color .2s}
.step.active .step-num{background:var(--accent);border-color:var(--accent-hi);color:#fff}
.step.active .step-label{color:var(--text)}
.step.done .step-num{background:#1a3a1a;border-color:var(--green);color:var(--green)}
.step.done .step-label{color:var(--muted)}
.sidebar-footer{padding:0 20px;font-size:11px;color:#3a4a5a;letter-spacing:.05em}

/* content */
#content{flex:1;overflow-y:auto;display:flex;align-items:flex-start;justify-content:center;padding:32px 24px}
.page{display:none;width:100%;max-width:640px}
.page.active{display:block}

/* card */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:32px 36px;margin-bottom:20px}
.card-title{font-size:22px;font-weight:700;margin-bottom:6px}
.card-sub{color:var(--muted);font-size:14px;margin-bottom:20px}
.divider{border:none;border-top:1px solid var(--border);margin:0 0 24px}

/* status */
.status-box{padding:14px 18px;border-radius:8px;font-size:13px;white-space:pre-line;line-height:1.6}
.status-info{background:#0c1e35;border:1px solid #1e3a5a;color:#7cb2ff}
.status-ok{background:#0a1f14;border:1px solid #1a4a2a;color:var(--green)}
.status-err{background:#1a080f;border:1px solid #4a1020;color:var(--red)}

/* buttons */
.btn-row{display:flex;gap:10px;margin-top:24px;justify-content:flex-end}
button{padding:9px 20px;border-radius:8px;border:1.5px solid var(--border);background:var(--surface2);color:var(--text);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s}
button:hover:not(:disabled){border-color:var(--accent);color:var(--accent-hi)}
button:disabled{opacity:.4;cursor:not-allowed}
button.primary{background:var(--accent);border-color:var(--accent);color:#fff}
button.primary:hover:not(:disabled){background:var(--accent-hi);border-color:var(--accent-hi);color:#fff}
button.danger{border-color:#4a1020;color:var(--red)}
button.danger:hover:not(:disabled){background:#1a080f;border-color:var(--red)}

/* disk grid */
.disk-grid{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.disk-card{display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:8px;border:1.5px solid var(--border);background:var(--surface2);cursor:pointer;transition:all .15s}
.disk-card:hover{border-color:var(--accent)}
.disk-card.selected{border-color:var(--accent);background:#0d1e3a}
.disk-icon{font-size:22px;flex-shrink:0}
.disk-info{flex:1;min-width:0}
.disk-name{font-weight:600;font-size:14px}
.disk-detail{color:var(--muted);font-size:12px;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.disk-size{font-size:13px;color:var(--accent-hi);font-weight:600;flex-shrink:0}
.disk-tools{display:flex;gap:8px;margin-top:8px}
.warn-box{background:#1a110a;border:1px solid #5a3000;border-radius:8px;padding:10px 14px;font-size:13px;color:var(--amber);margin:12px 0}

/* form fields */
.field-label{font-size:12px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin:16px 0 6px}
input[type=text],input[type=password],select{width:100%;padding:9px 12px;border-radius:8px;border:1.5px solid var(--border);background:var(--surface2);color:var(--text);font-size:14px;font-family:var(--font);outline:none;transition:border-color .15s}
input:focus,select:focus{border-color:var(--accent)}
select{cursor:pointer}

/* review table */
.review-table{width:100%;border-collapse:collapse;font-size:14px}
.review-table tr{border-bottom:1px solid var(--border)}
.review-table tr:last-child{border:none}
.review-table td{padding:10px 0}
.review-table td:first-child{color:var(--muted);width:40%;font-size:13px}
.review-table td:last-child{font-weight:500;padding-left:16px}
.review-wipe{background:#1a080f;border:1px solid #4a1020;border-radius:8px;padding:12px 16px;font-size:13px;color:var(--red);margin:16px 0}

/* progress */
.progress-wrap{margin:20px 0}
.progress-label{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;font-size:13px}
.progress-bar{height:8px;background:var(--surface2);border-radius:4px;overflow:hidden}
.progress-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .4s}
.progress-fill.pulsing{animation:pulse 1.5s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
.stats-row{display:flex;gap:16px;font-size:12px;color:var(--muted);margin-top:6px}

/* log */
.log-toggle{background:none;border:none;color:var(--muted);font-size:12px;padding:6px 0;cursor:pointer;display:flex;align-items:center;gap:4px}
.log-toggle:hover{color:var(--text)}
.log-arrow{transition:transform .2s;display:inline-block}
.log-arrow.open{transform:rotate(90deg)}
.log-wrap{display:none;background:#080808;border:1px solid var(--border);border-radius:8px;padding:12px 14px;font-family:var(--mono);font-size:12px;color:#888;line-height:1.7;max-height:280px;overflow-y:auto;margin-top:4px}
.log-wrap.open{display:block}
.log-cmd{color:#b8b8e8}
.log-sep{color:#243754}

/* done / error */
.hero-icon{font-size:48px;display:block;margin-bottom:14px}
.done-title{font-size:26px;font-weight:700;color:var(--green);margin-bottom:8px}
.err-title{font-size:26px;font-weight:700;color:var(--red);margin-bottom:8px}
.hero-body{font-size:14px;color:var(--muted);line-height:1.7}
.err-pre{font-size:12px;font-family:var(--mono);color:var(--red);background:#1a080f;border:1px solid #4a1020;border-radius:8px;padding:12px;margin:14px 0;white-space:pre-wrap;word-break:break-all}

::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
</style>
</head>
<body>
<div id="app">

<nav id="sidebar">
  <div class="logo">KythOS</div>
  <div class="steps" id="steps">
    <div class="step" data-step="welcome"><div class="step-num">1</div><div class="step-label">Welcome</div></div>
    <div class="step" data-step="disk">   <div class="step-num">2</div><div class="step-label">Disk</div></div>
    <div class="step" data-step="config"> <div class="step-num">3</div><div class="step-label">Configure</div></div>
    <div class="step" data-step="review"> <div class="step-num">4</div><div class="step-label">Review</div></div>
    <div class="step" data-step="install"><div class="step-num">5</div><div class="step-label">Install</div></div>
  </div>
  <div class="sidebar-footer">kyth installer</div>
</nav>

<div id="content">

  <!-- Welcome -->
  <div class="page active" id="page-welcome">
    <div class="card">
      <div class="card-title">Welcome to KythOS</div>
      <div class="card-sub">Immutable gaming &amp; development desktop — Fedora Kinoite + CachyOS kernel</div>
      <hr class="divider">
      <p style="color:var(--muted);line-height:1.8">
        This installer will guide you through installing KythOS on your computer.<br><br>
        <span style="color:var(--text)">What happens:</span><br>
        &nbsp; 1. Select a target disk<br>
        &nbsp; 2. Set hostname, timezone, and user account<br>
        &nbsp; 3. Download and write KythOS to disk<br><br>
        <span style="color:var(--amber)">⚠ The selected disk will be completely erased.</span><br>
        Back up any data you need before continuing.
      </p>
      <div class="btn-row">
        <button class="primary" onclick="goto('disk')">Get Started →</button>
      </div>
    </div>
  </div>

  <!-- Disk -->
  <div class="page" id="page-disk">
    <div class="card">
      <div class="card-title">Select Disk</div>
      <div class="card-sub">KythOS will be installed on the selected disk. All existing data will be erased.</div>
      <hr class="divider">
      <div class="disk-grid" id="disk-grid">
        <div class="status-box status-info">Loading disks…</div>
      </div>
      <div class="warn-box" id="disk-warn" style="display:none">⚠ All data on this disk will be permanently destroyed.</div>
      <div class="disk-tools">
        <button onclick="loadDisks()">Refresh</button>
      </div>
      <div class="btn-row">
        <button onclick="goto('welcome')">← Back</button>
        <button id="disk-next" class="primary" onclick="goto('config')" disabled>Continue →</button>
      </div>
    </div>
  </div>

  <!-- Config -->
  <div class="page" id="page-config">
    <div class="card">
      <div class="card-title">System Configuration</div>
      <div class="card-sub">Set hostname, timezone, and your user account</div>
      <hr class="divider">
      <div class="field-label">Hostname</div>
      <input type="text" id="inp-hostname" value="kyth" maxlength="63" spellcheck="false">
      <div class="field-label">Timezone</div>
      <select id="sel-tz"></select>
      <div class="field-label" style="margin-top:20px">Username</div>
      <input type="text" id="inp-username" maxlength="32" spellcheck="false" autocomplete="off" placeholder="e.g. alice">
      <div class="field-label">Password</div>
      <input type="password" id="inp-password" autocomplete="new-password">
      <div class="field-label">Confirm Password</div>
      <input type="password" id="inp-password2" autocomplete="new-password">
      <div id="user-error" style="color:var(--red);font-size:13px;margin-top:8px;min-height:1.2em"></div>
      <div class="btn-row">
        <button onclick="goto('disk')">← Back</button>
        <button class="primary" onclick="saveConfig()">Continue →</button>
      </div>
    </div>
  </div>

  <!-- Review -->
  <div class="page" id="page-review">
    <div class="card">
      <div class="card-title">Review &amp; Install</div>
      <div class="card-sub">Confirm settings — installation begins immediately after you click Install</div>
      <hr class="divider">
      <table class="review-table" id="review-table"></table>
      <div class="review-wipe">⚠ Everything on the selected disk will be permanently erased.</div>
      <div class="btn-row">
        <button onclick="goto('config')">← Back</button>
        <button class="primary" onclick="startInstall()">Install Now</button>
      </div>
    </div>
  </div>

  <!-- Install progress -->
  <div class="page" id="page-install">
    <div class="card" style="max-width:700px">
      <div class="card-title" id="install-title">Installing KythOS…</div>
      <div class="progress-wrap">
        <div class="progress-label">
          <span id="install-phase">Preparing…</span>
          <span id="install-elapsed" style="font-size:12px;color:var(--muted)"></span>
          <span id="install-pct">0%</span>
        </div>
        <div class="progress-bar"><div class="progress-fill pulsing" id="progress-fill" style="width:0%"></div></div>
        <div class="stats-row" id="stats-row"></div>
      </div>
      <button class="log-toggle" onclick="toggleLog()">
        <span class="log-arrow" id="log-arrow">▶</span> Show install log
      </button>
      <div class="log-wrap" id="log-wrap"></div>
    </div>
  </div>

  <!-- Done -->
  <div class="page" id="page-done">
    <div class="card" style="text-align:center;padding:48px 40px">
      <span class="hero-icon">✓</span>
      <div class="done-title">Installation Complete</div>
      <p class="hero-body">
        KythOS has been installed successfully.<br>
        Remove the installation media and reboot to start your new system.
      </p>
      <div class="btn-row" style="justify-content:center;margin-top:32px">
        <button class="primary" onclick="reboot()" style="padding:11px 32px;font-size:15px">Reboot Now</button>
      </div>
    </div>
  </div>

  <!-- Error -->
  <div class="page" id="page-error">
    <div class="card">
      <span class="hero-icon" style="font-size:36px">✗</span>
      <div class="err-title">Installation Failed</div>
      <div class="err-pre" id="err-msg"></div>
      <p style="font-size:12px;color:var(--muted)">Full log saved to /tmp/kyth-installer.log</p>
      <div class="btn-row">
        <button class="primary" onclick="goto('review')">← Back to Installer</button>
      </div>
    </div>
  </div>

</div><!-- #content -->
</div><!-- #app -->

<script>
const S = { disk: null, hostname: 'kyth', timezone: 'UTC', username: '', password: '' };
let SESSION_TOKEN = '';
const STEPS = ['welcome','disk','config','review','install'];

function apiFetch(url, opts={}) {
  const o = {...opts, credentials:'same-origin'};
  const h = new Headers(o.headers || {});
  if (SESSION_TOKEN) h.set('X-Kyth-Session-Token', SESSION_TOKEN);
  o.headers = h;
  return fetch(url, o);
}

// ── Navigation ────────────────────────────────────────────────────────────────
function goto(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.querySelectorAll('.step').forEach(el => {
    const si = STEPS.indexOf(el.dataset.step), ai = STEPS.indexOf(name);
    el.classList.toggle('done',   si < ai);
    el.classList.toggle('active', si === ai);
    // ai may be -1 for non-step pages (error, done) — never pass '' to remove()
    if (si < ai)  el.classList.remove('active');
    if (si === ai) el.classList.remove('done');
  });
  if (name === 'disk')    loadDisks();
  if (name === 'config')  initConfig();
  if (name === 'review')  buildReview();
}

// ── Disk ──────────────────────────────────────────────────────────────────────
let _disks = [];
function loadDisks(attempt) {
  attempt = attempt || 0;
  document.getElementById('disk-grid').innerHTML = '<div class="status-box status-info">Scanning for disks…</div>';
  document.getElementById('disk-next').disabled  = true;
  document.getElementById('disk-warn').style.display = 'none';
  S.disk = null;
  fetch('/api/disks').then(r=>r.json()).then(disks => {
    _disks = disks;
    const grid = document.getElementById('disk-grid');
    if (!disks.length) {
      if (attempt < 4) {
        setTimeout(() => loadDisks(attempt + 1), 1500);
      } else {
        grid.innerHTML = '<div class="status-box status-err">No disks found. Check that a disk is attached and click Refresh.</div>';
      }
      return;
    }
    grid.innerHTML = disks.map((d, i) => `
      <div class="disk-card" id="dcard-${i}" onclick="selectDisk(${i})">
        <div class="disk-icon">${d.rota ? '💿' : '💾'}</div>
        <div class="disk-info">
          <div class="disk-name">${d.name}</div>
          <div class="disk-detail">${d.model}${d.tran ? ' · '+d.tran.toUpperCase() : ''}</div>
        </div>
        <div class="disk-size">${d.size}</div>
      </div>`).join('');
  }).catch(() => {
    document.getElementById('disk-grid').innerHTML = '<div class="status-box status-err">Failed to load disk list.</div>';
  });
}
function selectDisk(idx) {
  document.querySelectorAll('.disk-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('dcard-' + idx).classList.add('selected');
  S.disk = _disks[idx];
  document.getElementById('disk-next').disabled = false;
  document.getElementById('disk-warn').style.display = 'block';
}

// ── Config ────────────────────────────────────────────────────────────────────
function initConfig() {
  const sel = document.getElementById('sel-tz');
  if (sel.options.length === 0) {
    fetch('/api/timezones').then(r=>r.json()).then(tzs => {
      const local = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      (tzs.length ? tzs : ['UTC']).forEach(tz => {
        const opt = document.createElement('option');
        opt.value = tz; opt.textContent = tz;
        if (tz === local) opt.selected = true;
        sel.appendChild(opt);
      });
    }).catch(() => {
      const opt = document.createElement('option');
      opt.value = 'UTC'; opt.textContent = 'UTC';
      opt.selected = true;
      sel.appendChild(opt);
    });
  }
}
function saveConfig() {
  const hostname = document.getElementById('inp-hostname').value.trim();
  const username = document.getElementById('inp-username').value.trim();
  const pw1      = document.getElementById('inp-password').value;
  const pw2      = document.getElementById('inp-password2').value;
  const errEl    = document.getElementById('user-error');
  errEl.textContent = '';

  if (!/^[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?$/.test(hostname)) {
    errEl.textContent = 'Hostname must contain only letters, digits, and hyphens.'; return;
  }
  if (!/^[a-z_][a-z0-9_-]{0,30}$/.test(username)) {
    errEl.textContent = 'Username must start with a letter, use only lowercase letters/digits/hyphens.'; return;
  }
  if (pw1.length < 1) { errEl.textContent = 'Password is required.'; return; }
  if (pw1 !== pw2)    { errEl.textContent = 'Passwords do not match.'; return; }

  S.hostname = hostname;
  S.timezone = document.getElementById('sel-tz').value;
  S.username = username;
  S.password = pw1;
  goto('review');
}

// ── Review ────────────────────────────────────────────────────────────────────
function buildReview() {
  const rows = [
    ['Disk',     S.disk ? `${S.disk.name}  (${S.disk.size})` : '—'],
    ['Model',    S.disk ? S.disk.model : '—'],
    ['Hostname', S.hostname],
    ['Timezone', S.timezone],
    ['Username', S.username],
    ['Password', '••••••••'],
    ['Source',   S._sourceImage || '—'],
  ];
  document.getElementById('review-table').innerHTML =
    rows.map(([k,v]) => `<tr><td>${k}</td><td>${v}</td></tr>`).join('');
}

// ── Install ───────────────────────────────────────────────────────────────────
let _startTime = 0;
let _elapsedTimer = null;

function startInstall() {
  goto('install');
  _startTime = Date.now();
  _elapsedTimer = setInterval(() => {
    const s = Math.floor((Date.now() - _startTime) / 1000);
    const m = Math.floor(s / 60), sec = s % 60;
    document.getElementById('install-elapsed').textContent =
      m > 0 ? `${m}m ${sec}s` : `${sec}s`;
  }, 1000);

  apiFetch('/api/start', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      disk: S.disk.name, hostname: S.hostname,
      timezone: S.timezone, username: S.username, password: S.password,
    }),
  }).then(r => {
    if (!r.ok) return r.text().then(t => showError('Failed to start install: ' + t)).catch(() => showError('Install request failed (status ' + r.status + ')'));
    listenSSE();
  }).catch(e => showError('Network error: ' + e));
}

function listenSSE() {
  const src = new EventSource('/api/stream');
  src.onmessage = e => {
    const ev = JSON.parse(e.data);
    if (ev.type === 'log')      appendLog(ev.text);
    else if (ev.type === 'progress') setProgress(ev.value);
    else if (ev.type === 'stats')    showStats(ev);
    else if (ev.type === 'done') { src.close(); onDone(); }
    else if (ev.type === 'error'){ src.close(); showError(ev.message); }
  };
  src.onerror = () => { src.close(); showError('Lost connection to installer backend.'); };
}

function setProgress(pct) {
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('install-pct').textContent   = pct + '%';
  const fill = document.getElementById('progress-fill');
  if (pct >= 100) fill.classList.remove('pulsing');
  const phases = {5:'Pulling OS image…',90:'Configuring…',95:'Creating user…',99:'Finalizing…'};
  for (const [p, label] of Object.entries(phases).reverse()) {
    if (pct >= parseInt(p)) { document.getElementById('install-phase').textContent = label; break; }
  }
}

function showStats(s) {
  const dl   = fmtBytes(s.downloaded), tot = fmtBytes(s.total);
  const spd  = fmtBytes(s.speed) + '/s';
  const eta  = s.eta_sec > 0 ? fmtEta(s.eta_sec) : '';
  document.getElementById('stats-row').textContent = `${dl} / ${tot}  ·  ${spd}${eta ? '  ·  ETA ' + eta : ''}`;
}

function fmtBytes(n) {
  if (n < 1024) return n + ' B';
  if (n < 1024**2) return (n/1024).toFixed(1) + ' KB';
  if (n < 1024**3) return (n/1024**2).toFixed(1) + ' MB';
  return (n/1024**3).toFixed(2) + ' GB';
}
function fmtEta(s) {
  if (s < 60) return s + 's';
  return Math.floor(s/60) + 'm ' + (s%60) + 's';
}

function appendLog(text) {
  const wrap = document.getElementById('log-wrap');
  const line = document.createElement('div');
  if (text.startsWith('$ '))       line.className = 'log-cmd';
  else if (text.startsWith('──')) line.className = 'log-sep';
  line.textContent = text;
  wrap.appendChild(line);
  wrap.scrollTop = wrap.scrollHeight;
}

function toggleLog() {
  const wrap  = document.getElementById('log-wrap');
  const arrow = document.getElementById('log-arrow');
  const open  = wrap.classList.toggle('open');
  arrow.classList.toggle('open', open);
}

function onDone() {
  clearInterval(_elapsedTimer);
  goto('done');
}

function showError(msg) {
  clearInterval(_elapsedTimer);
  document.getElementById('err-msg').textContent = msg;
  goto('error');
}

function reboot() {
  apiFetch('/api/reboot', {method:'POST'}).catch(()=>{});
}

// ── Init ──────────────────────────────────────────────────────────────────────
fetch('/api/config').then(r=>r.json()).then(cfg => {
  SESSION_TOKEN = cfg.session_token;
  S._sourceImage = cfg.source_image;
});
goto('welcome');
</script>
</body>
</html>"""


# ── Entry point ───────────────────────────────────────────────────────────────

class _Server(ThreadingHTTPServer):
    # Allow the port to be reused immediately if the previous process crashed
    # and left a TIME_WAIT socket — prevents EADDRINUSE on rapid restarts.
    allow_reuse_address = True


def main() -> None:
    server = _Server(("127.0.0.1", PORT), Handler)
    t = threading.Thread(target=server.serve_forever, daemon=True)
    t.start()
    time.sleep(0.3)

    # The installer runs as root (bootc requires it), but Chromium must run as
    # the desktop user so it can connect to the X display. sudo sets $SUDO_USER
    # to the original user; fall back to running Chromium directly if not set
    # (e.g. when testing as root without sudo).
    sudo_user = os.environ.get("SUDO_USER", "")
    chromium_cmd = [
        "chromium-browser",
        f"--app=http://127.0.0.1:{PORT}",
        "--disable-dev-shm-usage",
        "--disable-extensions",
        "--disable-translate",
        "--no-first-run",
        # Force software rendering: the GPU process crashes in QEMU virtio-gpu
        # with Mesa's EGL/ANGLE backend, which kills the whole Chromium window.
        "--disable-gpu",
        "--use-gl=swiftshader",
        "--window-size=1280,800",
        "--window-position=0,0",
    ]
    if sudo_user:
        proc = subprocess.Popen(["sudo", "-u", sudo_user, *chromium_cmd])
    else:
        # Running Chromium directly as root — the Linux user-namespace sandbox
        # requires a non-root UID to work, so disable it only in this path.
        proc = subprocess.Popen([chromium_cmd[0], "--no-sandbox", *chromium_cmd[1:]])

    # Wait for Chromium to exit so the process and port are released cleanly.
    # This means re-launching the installer from the desktop always gets a fresh server.
    try:
        proc.wait()
    except KeyboardInterrupt:
        proc.terminate()


if __name__ == "__main__":
    main()
