#!/usr/bin/env bash
# kyth-apply-update — zero-dependency update trigger for KythOS.
#
# Opened by the "Apply KythOS Update" app-menu entry. Designed to work even
# when KythOS Hub (Python/Qt) is broken. Requires only bootc, sudo, and bash.
# bootc upgrade is NOPASSWD for wheel users via /etc/sudoers.d/kyth-bootc-sudo.

set -euo pipefail

echo "━━━ KythOS Update ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Show current image so the user knows what they're running.
if CURRENT=$(sudo -n bootc status 2>/dev/null | grep -E "^\s*(Image|Digest|Timestamp)" | head -6); then
    echo "Current deployment:"
    echo "$CURRENT" | sed 's/^/  /'
    echo ""
fi

echo "Downloading and staging the latest KythOS image…"
echo "(This can take several minutes on a slow connection.)"
echo ""

if sudo -n bootc upgrade; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Update complete."
    echo "  Restart your PC when you're ready to apply it."
    echo "  The previous image remains available as a rollback from the boot menu."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
else
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Update failed — see output above for details."
    echo "  Common causes: no network, registry temporarily down, disk space low."
    echo "  If KythOS Hub is working, use the Updates page for richer diagnostics."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
fi

echo ""
read -rp "Press Enter to close…"
