#!/usr/bin/env bash
set -euo pipefail

RULE_FILE=/etc/udev/rules.d/61-kyth-nvme-tuning.rules

usage() {
    cat <<'EOF'
Usage: kyth-nvme-tuning <status|kyth|default>

  status   Show the selected profile and current NVMe queue settings.
  kyth     Enable the experimental KythOS NVMe profile and apply it now.
  default  Return to kernel defaults after the next reboot.
EOF
}

require_root() {
    if [[ $EUID -eq 0 ]]; then
        return 0
    fi

    exec sudo -A /usr/bin/kyth-nvme-tuning "$@"
}

show_status() {
    if [[ -e "$RULE_FILE" ]]; then
        echo "Selected profile: kyth (experimental)"
    else
        echo "Selected profile: default (kernel defaults)"
    fi

    local found=0 dev queue scheduler read_ahead wbt
    for dev in /sys/block/nvme*n*; do
        [[ -d "$dev" ]] || continue
        queue="${dev}/queue"
        [[ -r "${queue}/scheduler" ]] || continue
        found=1
        scheduler=$(< "${queue}/scheduler")
        read_ahead=$(< "${queue}/read_ahead_kb")
        wbt="unavailable"
        [[ -r "${queue}/wbt_lat_usec" ]] && wbt=$(< "${queue}/wbt_lat_usec")
        printf '%s: scheduler=%s read_ahead_kb=%s wbt_lat_usec=%s\n' \
            "$(basename "$dev")" "$scheduler" "$read_ahead" "$wbt"
    done

    [[ $found -eq 1 ]] || echo "No NVMe block devices detected."
}

enable_kyth() {
    require_root "$@"
    install -d -m 0755 /etc/udev/rules.d
    cat > "$RULE_FILE" <<'EOF'
# Experimental KythOS NVMe profile. Remove with: ujust nvme-tuning default
ACTION=="add|change", KERNEL=="nvme[0-9]*n[0-9]*", ATTR{queue/scheduler}="none"
ACTION=="add|change", KERNEL=="nvme[0-9]*n[0-9]*", ATTR{queue/read_ahead_kb}="2048"
ACTION=="add|change", KERNEL=="nvme[0-9]*n[0-9]*", ATTR{queue/wbt_lat_usec}="0"
EOF
    udevadm control --reload-rules
    udevadm trigger --action=change --subsystem-match=block --sysname-match='nvme*n*'
    echo "Enabled the experimental KythOS NVMe profile."
    show_status
}

enable_default() {
    require_root "$@"
    rm -f "$RULE_FILE"
    udevadm control --reload-rules
    echo "Selected kernel-default NVMe tuning. Reboot before benchmarking so the"
    echo "kernel and device drivers restore their original queue settings."
}

case "${1:-status}" in
    status)
        show_status
        ;;
    kyth)
        enable_kyth "$@"
        ;;
    default)
        enable_default "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
