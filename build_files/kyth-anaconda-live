#!/usr/bin/bash
# kyth-anaconda-live — Start anaconda with the Kyth kickstart for live sessions.
#
# This wrapper is used by the anaconda.service drop-in installed in the live image.
# When anaconda is started via systemctl from the live desktop (not via
# systemd.unit=anaconda.target at boot), /run/install/ks.cfg does not exist
# because it's an initramfs artifact. This wrapper:
#   1. Copies /etc/anaconda/kyth.ks → /run/install/ks.cfg so inst.ks path works
#   2. Exec's anaconda with --kickstart to load the source image config

set -euo pipefail

mkdir -p /run/install
install -m 644 /etc/anaconda/kyth.ks /run/install/ks.cfg

# Find the anaconda binary (location varies between Fedora releases)
ANACONDA=""
for candidate in /usr/sbin/anaconda /usr/bin/anaconda; do
    if [[ -x "${candidate}" ]]; then
        ANACONDA="${candidate}"
        break
    fi
done

if [[ -z "${ANACONDA}" ]]; then
    echo "ERROR: anaconda binary not found" >&2
    exit 1
fi

exec "${ANACONDA}" --kickstart /etc/anaconda/kyth.ks "$@"
