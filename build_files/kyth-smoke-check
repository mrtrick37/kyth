#!/usr/bin/env bash
# kyth-smoke-check — daily-driver readiness checks for KythOS.
#
# This command is intentionally read-only. It is meant for release validation,
# support triage, and users who want proof that the boring parts of the system
# are healthy before they trust it as a daily driver.

set -uo pipefail

STRICT=0
VERBOSE=0

usage() {
    cat <<'EOF'
Usage: kyth-smoke-check [--strict] [--verbose]

Checks update safety, desktop services, hardware basics, gaming readiness,
Windows migration helpers, and KythOS background services.

Exit codes:
  0  no failed checks
  1  warnings present and --strict was used
  2  one or more failed checks
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --strict) STRICT=1 ;;
        --verbose|-v) VERBOSE=1 ;;
        --help|-h) usage; exit 0 ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 64
            ;;
    esac
    shift
done

PASS_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0
CURRENT_SECTION=""

section() {
    CURRENT_SECTION="$1"
    printf '\n== %s ==\n' "$CURRENT_SECTION"
}

_line() {
    local status="$1"
    local name="$2"
    local detail="$3"
    printf '%-5s %-34s %s\n' "$status" "$name" "$detail"
}

pass() {
    PASS_COUNT=$((PASS_COUNT + 1))
    _line "PASS" "$1" "$2"
}

warn() {
    WARN_COUNT=$((WARN_COUNT + 1))
    _line "WARN" "$1" "$2"
}

fail() {
    FAIL_COUNT=$((FAIL_COUNT + 1))
    _line "FAIL" "$1" "$2"
}

have() {
    command -v "$1" >/dev/null 2>&1
}

run() {
    "$@" 2>/dev/null
}

first_line() {
    sed -n '1p'
}

check_command() {
    local cmd="$1"
    local label="${2:-$1}"
    if have "$cmd"; then
        pass "$label" "$(command -v "$cmd")"
    else
        fail "$label" "missing command"
    fi
}

check_optional_command() {
    local cmd="$1"
    local label="${2:-$1}"
    if have "$cmd"; then
        pass "$label" "$(command -v "$cmd")"
    else
        warn "$label" "not installed or unavailable on this image"
    fi
}

check_system_unit_active() {
    local unit="$1"
    local label="${2:-$1}"
    if ! have systemctl; then
        warn "$label" "systemctl unavailable"
        return
    fi
    if systemctl is-active --quiet "$unit" 2>/dev/null; then
        pass "$label" "active"
    elif systemctl list-unit-files "$unit" >/dev/null 2>&1; then
        warn "$label" "installed but not active"
    else
        fail "$label" "unit missing"
    fi
}

check_system_unit_enabled() {
    local unit="$1"
    local label="${2:-$1}"
    if ! have systemctl; then
        warn "$label" "systemctl unavailable"
        return
    fi
    if systemctl is-enabled --quiet "$unit" 2>/dev/null; then
        pass "$label" "enabled"
    elif systemctl list-unit-files "$unit" >/dev/null 2>&1; then
        warn "$label" "installed but not enabled"
    else
        fail "$label" "unit missing"
    fi
}

check_user_unit_active() {
    local unit="$1"
    local label="${2:-$1}"
    if ! have systemctl; then
        warn "$label" "systemctl unavailable"
        return
    fi
    if systemctl --user is-active --quiet "$unit" 2>/dev/null; then
        pass "$label" "active"
    else
        warn "$label" "not active in this user session"
    fi
}

flatpak_installed() {
    local app_id="$1"
    flatpak info "$app_id" >/dev/null 2>&1
}

check_flatpak() {
    local app_id="$1"
    local label="$2"
    if ! have flatpak; then
        fail "$label" "flatpak command missing"
    elif flatpak_installed "$app_id"; then
        pass "$label" "$app_id installed"
    else
        warn "$label" "$app_id missing; run sudo systemctl start kyth-default-flatpaks.service"
    fi
}

check_file() {
    local path="$1"
    local label="$2"
    if [[ -e "$path" ]]; then
        pass "$label" "$path"
    else
        fail "$label" "$path missing"
    fi
}

check_kernel_module_or_builtin() {
    local module="$1"
    local label="$2"
    if lsmod 2>/dev/null | awk '{print $1}' | grep -qx "$module"; then
        pass "$label" "$module loaded"
    elif modinfo "$module" >/dev/null 2>&1; then
        warn "$label" "$module available but not loaded"
    else
        warn "$label" "$module not available for this kernel/hardware"
    fi
}

short_bootc_ref() {
    local cmd=(bootc status --format json)
    if ! "${cmd[@]}" 2>/dev/null \
        | python3 -c 'import json,sys
s=json.load(sys.stdin)
img=s.get("status",{}).get("booted",{}).get("image",{}).get("image",{}).get("image","")
digest=s.get("status",{}).get("booted",{}).get("image",{}).get("imageDigest","")
print(img or digest or "unknown")' 2>/dev/null; then
        sudo -n bootc status --format json 2>/dev/null \
            | python3 -c 'import json,sys
s=json.load(sys.stdin)
img=s.get("status",{}).get("booted",{}).get("image",{}).get("image",{}).get("image","")
digest=s.get("status",{}).get("booted",{}).get("image",{}).get("imageDigest","")
print(img or digest or "unknown")' 2>/dev/null
    fi
}

read_deployment_status() {
    local dest="$1"
    DEPLOYMENT_STATUS_SOURCE=""

    if have bootc && bootc status >"$dest" 2>/dev/null; then
        DEPLOYMENT_STATUS_SOURCE="bootc"
        return 0
    fi

    if have sudo && sudo -n bootc status >"$dest" 2>/dev/null; then
        DEPLOYMENT_STATUS_SOURCE="bootc-sudo"
        return 0
    fi

    if have ostree && ostree admin status >"$dest" 2>/dev/null; then
        DEPLOYMENT_STATUS_SOURCE="ostree"
        return 0
    fi

    return 1
}

deployment_count() {
    if have ostree; then
        ostree admin status 2>/dev/null | grep -Ec '^\*? +[a-zA-Z0-9_-]+ ' || true
    else
        bootc status 2>/dev/null | grep -Ec 'Booted|Rollback|staged|Staged' || true
    fi
}

echo "KythOS Smoke Check"
echo "Generated: $(date -Is)"
echo "Host: $(hostname 2>/dev/null || echo unknown)"
echo "Kernel: $(uname -r 2>/dev/null || echo unknown)"

section "Identity And Update Safety"
if [[ -r /etc/os-release ]] && grep -q '^PRETTY_NAME="KythOS' /etc/os-release; then
    pass "OS identity" "$(grep '^PRETTY_NAME=' /etc/os-release | cut -d= -f2- | tr -d '"')"
else
    fail "OS identity" "/etc/os-release does not advertise KythOS"
fi

check_command bootc "bootc"
if have bootc; then
    if read_deployment_status /tmp/kyth-smoke-bootc.$$; then
        if [[ "$DEPLOYMENT_STATUS_SOURCE" == bootc* ]]; then
            ref="$(short_bootc_ref)"
            pass "Booted image" "${ref:-bootc status readable}"
        else
            ref="$(awk '/^\*/ {print $2; exit}' /tmp/kyth-smoke-bootc.$$)"
            pass "Booted deployment" "${ref:-ostree admin status readable} (bootc status requires root)"
        fi
        if [[ "$DEPLOYMENT_STATUS_SOURCE" == bootc* ]] && grep -qi 'staged' /tmp/kyth-smoke-bootc.$$; then
            warn "Staged update" "reboot before performance testing"
        else
            pass "Staged update" "none detected"
        fi
        deployments="$(deployment_count)"
        if [[ "${deployments:-0}" -ge 2 ]]; then
            pass "Rollback deployment" "${deployments} deployments visible"
        else
            warn "Rollback deployment" "only ${deployments:-0} deployment visible"
        fi
    else
        fail "bootc status" "unreadable"
    fi
    rm -f /tmp/kyth-smoke-bootc.$$
fi

check_system_unit_enabled kyth-selinux-relabel-home.service "SELinux home relabel"
check_system_unit_enabled kyth-first-boot-message.service "First boot message"
check_system_unit_enabled fstrim.timer "SSD trim timer"
check_system_unit_enabled fwupd.service "Firmware service"

section "Desktop Familiarity"
if [[ "${XDG_CURRENT_DESKTOP:-}" == *KDE* || "${DESKTOP_SESSION:-}" == plasma* ]]; then
    pass "Desktop session" "${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-unknown}}"
else
    warn "Desktop session" "${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-unknown}}"
fi
check_system_unit_enabled display-manager.service "Login manager"
check_file /usr/share/wallpapers/kyth/metadata.json "KythOS wallpaper"
check_file /usr/share/applications/kyth-welcome.desktop "System Hub launcher"
check_file /etc/skel/.config/kickoffrc "Pinned app defaults"
check_file /etc/skel/.config/baloofilerc "Baloo quiet default"
check_file /usr/bin/kyth-user-polish "User comfort polish"
check_file /etc/xdg/autostart/kyth-user-polish.desktop "Automatic user polish"
check_file /etc/xdg/mimeapps.list "Default app associations"
check_file /usr/bin/kyth-post-update-check "Post-update confidence"
check_file /etc/xdg/autostart/kyth-post-update-check.desktop "Auto post-update check"
check_file /usr/bin/kyth-firstboot-app-status "App setup notifier"
check_file /etc/xdg/autostart/kyth-firstboot-app-status.desktop "Auto app setup notifier"
check_file /etc/skel/Games "Games folder default"
check_file /usr/bin/kyth-windows-friendly-defaults "Windows-friendly defaults"
check_file /usr/bin/kyth-exe-handler "Windows app helper"

if [[ -r /etc/xdg/mimeapps.list ]] && grep -q '^application/x-msi=kyth-exe-handler.desktop' /etc/xdg/mimeapps.list; then
    pass "MSI helper association" "Windows installers open KythOS helper"
else
    warn "MSI helper association" "application/x-msi is not mapped to kyth-exe-handler.desktop"
fi

if [[ -r "${HOME}/.config/kdeglobals" ]]; then
    if grep -q '^SingleClick=false' "${HOME}/.config/kdeglobals"; then
        pass "Double-click default" "user config uses Windows-style open behavior"
    else
        warn "Double-click default" "run /usr/bin/kyth-user-polish or log out/in after updating"
    fi
else
    warn "Double-click default" "user KDE config not created yet; /usr/bin/kyth-user-polish applies it after login"
fi

section "Core Daily-Driver Services"
check_system_unit_active NetworkManager.service "Network manager"
check_system_unit_active bluetooth.service "Bluetooth"
check_system_unit_enabled kyth-bluetooth-enable.service "Bluetooth auto-enable"
check_system_unit_active rtkit-daemon.service "Realtime audio helper"
check_user_unit_active pipewire.service "PipeWire"
check_user_unit_active wireplumber.service "WirePlumber"
check_system_unit_enabled cups-browsed.service "Printer discovery"
check_system_unit_enabled irqbalance.service "IRQ balancing"

section "Hardware And Drivers"
check_command lspci "PCI hardware probe"
if have lspci; then
    gpu_lines="$(lspci -nn 2>/dev/null | grep -Ei 'vga|3d|display' || true)"
    if [[ -n "$gpu_lines" ]]; then
        pass "GPU detected" "$(printf '%s\n' "$gpu_lines" | first_line)"
        if grep -qi nvidia <<<"$gpu_lines"; then
            if lsmod 2>/dev/null | grep -q '^nvidia '; then
                pass "NVIDIA driver" "proprietary module loaded"
            elif rpm -q akmod-nvidia >/dev/null 2>&1; then
                warn "NVIDIA driver" "akmod installed; reboot/build may still be needed"
            else
                fail "NVIDIA driver" "NVIDIA GPU present but akmod-nvidia missing"
            fi
        fi
        if grep -Eiq 'amd|ati' <<<"$gpu_lines"; then
            check_kernel_module_or_builtin amdgpu "AMD GPU driver"
        fi
        if grep -iq intel <<<"$gpu_lines"; then
            check_kernel_module_or_builtin i915 "Intel GPU driver"
        fi
    else
        warn "GPU detected" "no VGA/3D/display adapter found"
    fi
fi

if have vulkaninfo; then
    if timeout 10 vulkaninfo --summary >/tmp/kyth-smoke-vulkan.$$ 2>/dev/null; then
        device="$(grep -m1 'deviceName' /tmp/kyth-smoke-vulkan.$$ | sed 's/.*= //')"
        pass "Vulkan" "${device:-vulkaninfo works}"
    else
        fail "Vulkan" "vulkaninfo failed"
    fi
    rm -f /tmp/kyth-smoke-vulkan.$$
else
    warn "Vulkan" "vulkaninfo unavailable; install vulkan-tools for deeper validation"
fi

if compgen -G "/sys/class/bluetooth/hci*" >/dev/null; then
    if have rfkill && rfkill list bluetooth 2>/dev/null | grep -qi 'Soft blocked: yes\|Hard blocked: yes'; then
        warn "Bluetooth adapter" "present but blocked by rfkill"
    else
        pass "Bluetooth adapter" "controller present"
    fi
elif have rfkill && rfkill list bluetooth >/dev/null 2>&1; then
    warn "Bluetooth adapter" "rfkill knows bluetooth, but no hci controller is exposed"
else
    warn "Bluetooth adapter" "no controller reported"
fi

section "Gaming Stack"
check_optional_command gamemoderun "GameMode wrapper"
check_optional_command gamescope "Gamescope"
check_optional_command mangohud "MangoHud"
check_optional_command kyth-gamescope "KythOS Gamescope presets"
check_optional_command kyth-performance-mode "KythOS performance modes"
check_optional_command kyth-ge-proton-update "GE-Proton updater"
check_optional_command umu-run "umu launcher"
check_file /etc/gamemode.ini "GameMode config"
check_file /etc/MangoHud/MangoHud.conf "MangoHud config"
check_file /etc/vkBasalt.conf "vkBasalt config"

if [[ -e /dev/ntsync ]]; then
    pass "NTSYNC" "/dev/ntsync present"
else
    warn "NTSYNC" "not present; Proton will fall back to fsync/esync"
fi

if [[ -d /usr/share/steam/compatibilitytools.d ]] \
    || [[ -d "${HOME}/.steam/root/compatibilitytools.d" ]] \
    || [[ -d "${HOME}/.local/share/Steam/compatibilitytools.d" ]]; then
    pass "Proton runners" "compatibility tool directory present"
else
    warn "Proton runners" "GE-Proton may not be installed yet"
fi

check_flatpak com.valvesoftware.Steam "Steam Flatpak"
check_flatpak net.lutris.Lutris "Lutris Flatpak"
check_flatpak com.heroicgameslauncher.hgl "Heroic Flatpak"
check_flatpak com.usebottles.bottles "Bottles Flatpak"
check_flatpak com.github.mtkennerly.ludusavi "Ludusavi Flatpak"

section "Windows Migration And App Comfort"
check_command ntfs-3g "NTFS support"
check_command rsync "Migration copy tool"
check_file /usr/bin/kyth-exe-handler ".exe safety handler"
check_file /usr/share/applications/kyth-exe-handler.desktop ".exe desktop handler"
check_command mount.cifs "SMB share support"
if have lsblk; then
    ntfs_count="$(lsblk -nr -o FSTYPE 2>/dev/null | grep -c '^ntfs' || true)"
    if [[ "${ntfs_count:-0}" -gt 0 ]]; then
        warn "Windows drives" "${ntfs_count} NTFS partition(s) detected; confirm clean shutdown before copying"
    else
        pass "Windows drives" "no NTFS volumes detected"
    fi
fi

section "KythOS Background Work"
check_system_unit_enabled kyth-hw-setup.service "First-boot hardware setup"
check_system_unit_enabled kyth-flathub-setup.service "Flathub setup"
check_system_unit_enabled kyth-default-flatpaks.service "Default Flatpaks"
check_system_unit_enabled kyth-ge-proton-update.timer "GE-Proton timer"
check_system_unit_enabled kyth-duperemove.timer "Game cache dedupe timer"
check_system_unit_enabled kyth-topgrade-migrate.service "Topgrade migration"
check_system_unit_enabled kyth-local-bin-migrate.service "Local bin migration"
check_file /usr/share/ublue-os/just/75-kyth.just "KythOS ujust recipes"
check_optional_command kyth-device-info "Support snapshot"
check_optional_command kyth-controller-check "Controller check"
check_optional_command kyth-resume-check "Resume check"
check_optional_command kyth-nvidia-status "NVIDIA status check"

if [[ "$VERBOSE" -eq 1 ]]; then
    section "Verbose Context"
    echo "-- bootc status --"
    bootc status 2>/dev/null || true
    echo
    echo "-- flatpak apps --"
    flatpak list --app --columns=application,name,installation 2>/dev/null || true
    echo
    echo "-- recent warnings --"
    journalctl -b -p warning --no-pager -n 30 2>/dev/null || true
fi

printf '\n== Summary ==\n'
printf 'PASS: %d\n' "$PASS_COUNT"
printf 'WARN: %d\n' "$WARN_COUNT"
printf 'FAIL: %d\n' "$FAIL_COUNT"

if [[ "$FAIL_COUNT" -gt 0 ]]; then
    echo "Result: not daily-driver ready yet. Fix failed checks first."
    exit 2
fi

if [[ "$WARN_COUNT" -gt 0 ]]; then
    echo "Result: usable, with warnings to review."
    [[ "$STRICT" -eq 1 ]] && exit 1
    exit 0
fi

echo "Result: daily-driver smoke check is clean."
exit 0
