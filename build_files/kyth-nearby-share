#!/usr/bin/env bash
# Dolphin helper for sending selected files through KDE Connect.
set -euo pipefail

if (($# == 0)); then
    kdeconnect-app >/dev/null 2>&1 &
    exit 0
fi

if ! command -v kdeconnect-cli >/dev/null 2>&1; then
    kdialog --sorry "KDE Connect is not available on this system." --title "Nearby Sharing"
    exit 1
fi

mapfile -t device_rows < <(kdeconnect-cli --list-available --id-name-only 2>/dev/null)
if ((${#device_rows[@]} == 0)); then
    kdeconnect-app >/dev/null 2>&1 &
    kdialog --sorry \
        "No paired nearby device is reachable. Pair a phone or PC in KDE Connect, then try again." \
        --title "Nearby Sharing"
    exit 1
fi

device_id=""
if ((${#device_rows[@]} == 1)); then
    read -r device_id _ <<<"${device_rows[0]}"
else
    menu_args=()
    for row in "${device_rows[@]}"; do
        read -r id name <<<"${row}"
        [[ -z "${name}" ]] && name="${id}"
        menu_args+=("${id}" "${name}")
    done
    device_id=$(kdialog --title "Nearby Sharing" --menu "Send to which device?" "${menu_args[@]}") || exit 0
fi

sent=0
for path in "$@"; do
    if kdeconnect-cli --device "${device_id}" --share "${path}" >/dev/null 2>&1; then
        ((sent += 1))
    fi
done

if ((sent > 0)); then
    notify-send "Nearby Sharing" "Sent ${sent} item(s) through KDE Connect."
else
    kdialog --error "The selected files could not be sent." --title "Nearby Sharing"
    exit 1
fi
