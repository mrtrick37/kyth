#!/usr/bin/env python3
"""KythOS update notifier — unified OS + Flatpak update tray.

Autostarted at login via /etc/skel/.config/autostart/. Checks every 4 hours:
  - OS image: compares running bootc digest against registry manifest via skopeo.
  - Flatpak apps: counts pending app updates via `flatpak remote-ls --updates`.
Shows a single tray icon for both; left-click opens kyth-welcome on the Update page.
Single-instance guarded via a PID lock file.
"""

import hashlib
import json
import os
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

from PyQt6.QtCore import QThread, QTimer, pyqtSignal
from PyQt6.QtGui import QIcon
from PyQt6.QtWidgets import QApplication, QMenu, QSystemTrayIcon

REGISTRY = "ghcr.io/mrtrick37/kyth"
CHECK_INTERVAL_MS = 4 * 60 * 60 * 1000   # 4 hours
_LOCK_FILE = Path.home() / ".cache" / "kyth" / "kyth-update-notifier.lock"
_NOTIFIED_DIGEST_FILE = Path.home() / ".config" / "kyth-update-notified-digest"
_STAGED_NOTIFIED_FILE = Path.home() / ".config" / "kyth-update-staged-notified-digest"
_WELCOME_DONE_FILE = Path.home() / ".config" / "kyth-welcome-done"


# ── Helpers (duplicated from kyth-welcome to keep notifier self-contained) ────

def _bootc_status_data() -> dict | None:
    for cmd in (["sudo", "-n", "bootc", "status", "--json"], ["bootc", "status", "--json"]):
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        except Exception:
            continue
        if r.returncode != 0 or not r.stdout.strip():
            continue
        try:
            return json.loads(r.stdout)
        except json.JSONDecodeError:
            continue
    return None


def _bootc_status_text() -> str:
    for cmd in (["sudo", "-n", "bootc", "status"], ["bootc", "status"]):
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        except Exception:
            continue
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    return ""


def _nested_get(data: object, path: tuple[str, ...]) -> object | None:
    current = data
    for key in path:
        if not isinstance(current, dict):
            return None
        current = current.get(key)
    return current


def _walk_strings(data: object):
    if isinstance(data, str):
        yield data
        return
    if isinstance(data, dict):
        for value in data.values():
            yield from _walk_strings(value)
        return
    if isinstance(data, list):
        for value in data:
            yield from _walk_strings(value)


def _bootc_image_reference() -> str | None:
    data = _bootc_status_data() or {}
    candidates = (
        ("status", "booted", "image", "reference"),
        ("status", "booted", "image", "image", "reference"),
        ("status", "booted", "image", "image", "image"),
        ("status", "booted", "image", "image"),
        ("status", "booted", "image"),
        ("spec", "image", "image"),
        ("spec", "image", "reference"),
    )
    for path in candidates:
        value = _nested_get(data, path)
        if isinstance(value, str) and value.strip():
            return value.strip()
    for value in _walk_strings(data):
        stripped = value.strip()
        if REGISTRY in stripped:
            return stripped
    text = _bootc_status_text()
    if text:
        pattern = re.compile(rf"({re.escape(REGISTRY)}(?::[A-Za-z0-9._-]+)?(?:@sha256:[a-fA-F0-9]+)?)")
        match = pattern.search(text)
        if match:
            return match.group(1)
    return None


def _branch_from_ref(ref: str | None) -> str | None:
    if not ref:
        return None
    ref = ref.strip()
    if not ref:
        return None
    # Strip digest suffix before extracting the tag so testing-cachy@sha256:…
    # isn't mistakenly shortened to "testing" by a substring match.
    base = ref.split("@", 1)[0] if "@" in ref else ref
    if ":" in base:
        tag = base.rsplit(":", 1)[-1]
        if tag:
            return tag
    return None


def _current_branch() -> str:
    return _branch_from_ref(_bootc_image_reference()) or "latest"


def _staged_image_digest() -> str | None:
    """Return the sha256 digest of the locally staged image, or None if no staged update."""
    data = _bootc_status_data() or {}
    staged = (_nested_get(data, ("status", "staged")) or {})
    for path in (
        ("image", "imageDigest"),
        ("image", "digest"),
        ("imageDigest",),
        ("digest",),
    ):
        v = _nested_get(staged, path)
        if isinstance(v, str) and v.startswith("sha256:"):
            return v
    return None


# ── Restart action worker ─────────────────────────────────────────────────────

class RestartActionWorker(QThread):
    """Sends a persistent notification with a 'Restart Now' action button and
    emits restart_clicked if the user activates it."""
    restart_clicked = pyqtSignal()

    def __init__(self, title: str, body: str):
        super().__init__()
        self._title = title
        self._body = body

    def run(self):
        try:
            r = subprocess.run(
                [
                    "notify-send",
                    "--app-name=KythOS",
                    "--icon=system-reboot",
                    "--urgency=normal",
                    "--action=restart:Restart Now",
                    "--wait",
                    self._title,
                    self._body,
                ],
                capture_output=True, text=True, timeout=7200,
            )
            if r.returncode == 0 and "restart" in r.stdout:
                self.restart_clicked.emit()
        except Exception:
            pass


# ── Update check worker ───────────────────────────────────────────────────────

class UpdateCheckWorker(QThread):
    result = pyqtSignal(str, str)  # (state, digest): state = staged|available|uptodate|unknown|error

    def run(self):
        # Fast path: a staged image is already waiting locally — no registry call needed.
        local_data = _bootc_status_data() or {}
        staged_section = _nested_get(local_data, ("status", "staged"))
        if staged_section is not None:
            digest = _staged_image_digest() or ""
            self.result.emit("staged", digest)
            return

        booted = _nested_get(local_data, ("status", "booted")) or {}
        local_digest = None
        for path in (
            ("image", "imageDigest"),
            ("image", "digest"),
            ("imageDigest",),
            ("digest",),
        ):
            v = _nested_get(booted, path)
            if isinstance(v, str) and v.startswith("sha256:"):
                local_digest = v
                break

        if not local_digest:
            self.result.emit("unknown", "")
            return

        tag = _current_branch()
        ref = f"{REGISTRY}:{tag}"

        try:
            r = subprocess.run(
                ["skopeo", "inspect", "--raw", "--no-creds", f"docker://{ref}"],
                capture_output=True, timeout=45,
            )
        except Exception:
            self.result.emit("error", "")
            return

        if r.returncode != 0:
            self.result.emit("error", "")
            return

        # bootc stores the platform-specific (amd64) manifest digest in imageDigest,
        # not the OCI image index digest. Parse the index to extract the amd64 entry.
        # Fall back to hashing the raw bytes for single-arch images with no index.
        remote_digest = None
        try:
            manifest = json.loads(r.stdout)
            for entry in manifest.get("manifests", []):
                plat = entry.get("platform", {})
                if plat.get("architecture") == "amd64" and plat.get("os") == "linux":
                    d = entry.get("digest", "")
                    if d.startswith("sha256:"):
                        remote_digest = d
                    break
        except Exception:
            pass

        if remote_digest is None:
            remote_digest = "sha256:" + hashlib.sha256(r.stdout).hexdigest()

        if local_digest and remote_digest == local_digest:
            self.result.emit("uptodate", remote_digest)
        else:
            self.result.emit("available", remote_digest)


# ── Flatpak update check worker ───────────────────────────────────────────────

class FlatpakUpdateCheckWorker(QThread):
    """Counts pending Flatpak app updates. Emits count (0 = all up to date)."""
    result = pyqtSignal(int)  # number of pending Flatpak updates

    def run(self):
        try:
            # Refresh remote metadata first (fast, no downloads)
            subprocess.run(
                ["flatpak", "update", "--appstream", "--noninteractive"],
                capture_output=True, timeout=60,
            )
            r = subprocess.run(
                ["flatpak", "remote-ls", "--updates", "--columns=ref"],
                capture_output=True, text=True, timeout=30,
            )
            count = len([l for l in r.stdout.splitlines() if l.strip()])
            self.result.emit(count)
        except Exception:
            self.result.emit(0)


# ── Tray icon ─────────────────────────────────────────────────────────────────

class UpdateNotifier(QSystemTrayIcon):
    def __init__(self):
        super().__init__()
        self._worker = None
        self._flatpak_worker = None
        self._restart_worker = None
        self._update_available = False
        self._flatpak_updates = 0

        self._set_icon_normal()
        self.setToolTip("KythOS: Checking for updates…")

        menu = QMenu()
        self._status_action = menu.addAction("Checking for updates…")
        self._status_action.setEnabled(False)
        menu.addSeparator()
        self._restart_menu_action = menu.addAction("Restart to Apply", self._do_restart)
        self._restart_menu_action.setVisible(False)
        self._flatpak_action = menu.addAction("Checking Flatpak updates…")
        self._flatpak_action.setEnabled(False)
        self._update_flatpak_btn = menu.addAction("Update Apps Now", self._update_flatpak_now)
        self._update_flatpak_btn.setVisible(False)
        menu.addAction("Check Now", self._check_now)
        menu.addAction("Open KythOS Hub", self._open_hub)
        menu.addSeparator()
        menu.addAction("Quit", QApplication.instance().quit)
        self.setContextMenu(menu)

        self.activated.connect(self._on_activated)

        self._timer = QTimer(self)
        self._timer.timeout.connect(self._check_now)
        self._timer.start(CHECK_INTERVAL_MS)

        # Delay initial check so the session has time to fully settle
        QTimer.singleShot(15_000, self._check_now)
        QTimer.singleShot(60_000, self._check_flatpak)

    def _set_icon_normal(self):
        for name in ("system-software-update", "software-update-available", "view-refresh"):
            icon = QIcon.fromTheme(name)
            if not icon.isNull():
                self.setIcon(icon)
                return

    def _set_icon_update(self):
        for name in ("software-update-available", "system-software-update-urgent", "emblem-important"):
            icon = QIcon.fromTheme(name)
            if not icon.isNull():
                self.setIcon(icon)
                return

    def _set_icon_restart(self):
        for name in ("system-reboot", "system-restart", "system-software-update-urgent", "emblem-important"):
            icon = QIcon.fromTheme(name)
            if not icon.isNull():
                self.setIcon(icon)
                return

    def _do_restart(self):
        subprocess.Popen(["systemctl", "reboot"])

    def _check_flatpak(self):
        if self._flatpak_worker and self._flatpak_worker.isRunning():
            return
        self._flatpak_worker = FlatpakUpdateCheckWorker()
        self._flatpak_worker.result.connect(self._on_flatpak_result)
        self._flatpak_worker.start()

    def _on_flatpak_result(self, count: int):
        self._flatpak_updates = count
        if count > 0:
            self._flatpak_action.setText(f"{count} app update{'s' if count != 1 else ''} available")
            self._update_flatpak_btn.setVisible(True)
            self.show()
            self._refresh_tooltip()
        else:
            self._flatpak_action.setText("Apps up to date")
            self._update_flatpak_btn.setVisible(False)
            self._refresh_tooltip()

    def _update_flatpak_now(self):
        subprocess.Popen(["flatpak", "update", "-y", "--noninteractive"])

    def _refresh_tooltip(self):
        parts = []
        if self._update_available:
            parts.append("OS update available")
        if self._flatpak_updates > 0:
            parts.append(f"{self._flatpak_updates} app update{'s' if self._flatpak_updates != 1 else ''}")
        if parts:
            self.setToolTip("KythOS: " + " · ".join(parts))
            self.show()
        else:
            checked = datetime.now().strftime("%H:%M")
            self.setToolTip(f"KythOS: Up to date (checked {checked})")

    def _check_now(self):
        if self._worker and self._worker.isRunning():
            return
        self._worker = UpdateCheckWorker()
        self._worker.result.connect(self._on_result)
        self._worker.start()

    def _on_result(self, state: str, digest: str):
        if state == "staged":
            self._update_available = True
            self._set_icon_restart()
            self._status_action.setText("Update ready — restart to apply")
            self._restart_menu_action.setVisible(True)
            self._refresh_tooltip()
            self.show()

            # Notify once per staged digest; re-notify when a newer staging arrives.
            last_staged = ""
            if _STAGED_NOTIFIED_FILE.exists():
                try:
                    last_staged = _STAGED_NOTIFIED_FILE.read_text().strip()
                except Exception:
                    pass
            if digest and digest != last_staged:
                try:
                    _STAGED_NOTIFIED_FILE.write_text(digest)
                except Exception:
                    pass
                if self._restart_worker is None or not self._restart_worker.isRunning():
                    self._restart_worker = RestartActionWorker(
                        "KythOS update ready",
                        "New OS image staged. Restart when you are ready to apply it.",
                    )
                    self._restart_worker.restart_clicked.connect(self._do_restart)
                    self._restart_worker.start()

        elif state == "available":
            self._update_available = True
            self._set_icon_update()
            self._status_action.setText("Update available — click to open hub")
            self._restart_menu_action.setVisible(False)
            self._refresh_tooltip()
            self.show()

            # Notify once per distinct remote digest to avoid spam
            last_notified = ""
            if _NOTIFIED_DIGEST_FILE.exists():
                try:
                    last_notified = _NOTIFIED_DIGEST_FILE.read_text().strip()
                except Exception:
                    pass
            if digest and digest != last_notified:
                try:
                    _NOTIFIED_DIGEST_FILE.write_text(digest)
                except Exception:
                    pass
                subprocess.Popen([
                    "notify-send",
                    "--icon=software-update-available",
                    "--app-name=KythOS",
                    "--urgency=normal",
                    "KythOS Update Available",
                    "A new system image is ready to download. Open KythOS Hub to update.",
                ])

        elif state == "uptodate":
            self._update_available = False
            self._set_icon_normal()
            self._restart_menu_action.setVisible(False)
            checked = datetime.now().strftime("%H:%M")
            self._status_action.setText(f"OS up to date  ·  checked {checked}")
            self._refresh_tooltip()
            if self._flatpak_updates == 0:
                self.hide()

        elif state == "unknown":
            self._update_available = False
            self._set_icon_normal()
            self._restart_menu_action.setVisible(False)
            checked = datetime.now().strftime("%H:%M")
            self._status_action.setText(f"OS status unavailable  ·  checked {checked}")
            self._refresh_tooltip()
            if self._flatpak_updates == 0:
                self.hide()

        # On error: preserve previous state — transient network failures are common

    def _open_hub(self):
        subprocess.Popen(["kyth-welcome-launch", "--page", "Update"])

    def _on_activated(self, reason):
        if reason == QSystemTrayIcon.ActivationReason.Trigger:
            self._open_hub()


# ── Entry point ───────────────────────────────────────────────────────────────

def _acquire_lock() -> bool:
    """Returns True if this process is now the sole instance, False if another is running."""
    _LOCK_FILE.parent.mkdir(parents=True, exist_ok=True)
    try:
        if _LOCK_FILE.exists():
            pid_text = _LOCK_FILE.read_text().strip()
            if pid_text.isdigit():
                pid = int(pid_text)
                try:
                    os.kill(pid, 0)
                    return False  # still alive
                except (ProcessLookupError, PermissionError):
                    pass  # stale lock
        _LOCK_FILE.write_text(str(os.getpid()))
        return True
    except Exception:
        return True  # can't check — proceed anyway


def main():
    # Keep first login focused on onboarding. The notifier starts normally on
    # the next login after the wizard is completed or skipped.
    if not _WELCOME_DONE_FILE.exists():
        sys.exit(0)

    if not _acquire_lock():
        sys.exit(0)

    try:
        app = QApplication(sys.argv)
        app.setApplicationName("kyth-update-notifier")
        app.setQuitOnLastWindowClosed(False)

        if not QSystemTrayIcon.isSystemTrayAvailable():
            sys.exit(0)

        notifier = UpdateNotifier()  # must stay in scope for the duration
        exit_code = app.exec()
    finally:
        try:
            _LOCK_FILE.unlink(missing_ok=True)
        except Exception:
            pass

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
