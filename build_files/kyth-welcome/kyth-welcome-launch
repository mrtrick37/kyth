#!/usr/bin/env bash
set -u

log_dir="${XDG_CACHE_HOME:-${HOME}/.cache}/kyth"
if ! mkdir -p "${log_dir}" 2>/dev/null; then
    exec /usr/bin/kyth-welcome "$@"
fi

log_file="${log_dir}/kyth-welcome.log"
status=0

{
    echo "==== $(date -Is) kyth-welcome launch ===="
    echo "user=$(id -un 2>/dev/null || true) uid=$(id -u 2>/dev/null || true)"
    echo "DISPLAY=${DISPLAY-}"
    echo "WAYLAND_DISPLAY=${WAYLAND_DISPLAY-}"
    echo "XDG_SESSION_TYPE=${XDG_SESSION_TYPE-}"
    echo "QT_QPA_PLATFORM=${QT_QPA_PLATFORM-}"
    /usr/bin/kyth-welcome "$@"
    status=$?
    if [[ "${status}" -ne 0 ]]; then
        echo "kyth-welcome launch failed: exit ${status}"
    fi
} >>"${log_file}" 2>&1

if [[ "${status}" -eq 0 ]]; then
    exit 0
fi

report_dir="${XDG_STATE_HOME:-${HOME}/.local/state}/kyth"
mkdir -p "${report_dir}" 2>/dev/null || exit "${status}"
body_file="${report_dir}/system-hub-crash-$(date +%Y%m%d-%H%M%S).md"

{
    echo "## What happened"
    echo
    echo "System Hub exited unexpectedly."
    echo
    echo "## Crash context"
    echo
    echo "- Exit code: ${status}"
    echo "- Session: ${XDG_SESSION_TYPE:-unknown}"
    echo "- Display: DISPLAY=${DISPLAY-} WAYLAND_DISPLAY=${WAYLAND_DISPLAY-}"
    echo "- Qt platform: ${QT_QPA_PLATFORM:-default}"
    echo
    echo "## Recent System Hub launch log"
    echo
    echo '```text'
    tail -n 120 "${log_file}" 2>/dev/null || true
    echo '```'
    echo
    echo "## Notes"
    echo
    echo "Add what you were doing immediately before the crash, then submit the issue."
} > "${body_file}"

if command -v /usr/bin/kyth-report-issue >/dev/null 2>&1; then
    /usr/bin/kyth-report-issue \
        --title "System Hub crashed on launch" \
        --body-file "${body_file}" \
        --label "bug" \
        >/dev/null 2>&1 || true
fi

exit "${status}"
