            "font-family: 'Noto Mono', 'Cascadia Code', monospace; font-size: 12px;"
        )
        self._add(self._diag_report)

        self._stretch()
        self.refresh()

    def refresh(self):
        self._refresh_btn.setEnabled(False)
        self._status_lbl.setText("Running hardware probes…")
        self._status_lbl.setObjectName("subheading")
        _restyle(self._status_lbl)
        self._progress.show()

        self._worker = HardwareProbeWorker()
        self._worker.done.connect(self._on_done)
        self._worker.failed.connect(self._on_failed)
        self._worker.start()

    def _replace_cards(self, probes: list[HardwareProbe]):
        while self._card_col.count():
            item = self._card_col.takeAt(0)
            if w := item.widget():
                w.deleteLater()
        self._cards = []
        for probe in probes:
            card = HardwareCard(probe)
            self._cards.append(card)
            self._card_col.addWidget(card)

    def _on_done(self, probes: list[HardwareProbe]):
        self._progress.hide()
        self._refresh_btn.setEnabled(True)
        self._diag_refresh_btn.setEnabled(True)
        _finish_worker(self)
        self._replace_cards(probes)
        self._last_probes = probes

        levels = {p.status for p in probes}
        if "err" in levels:
            self._status_lbl.setText("One or more issues need attention.")
            self._status_lbl.setObjectName("status-err")
            self._diag_status_lbl.setText("Issues found — review before filing a bug.")
            self._diag_status_lbl.setObjectName("status-err")
        elif "warn" in levels:
            self._status_lbl.setText("Mostly healthy — a few items worth checking.")
            self._status_lbl.setObjectName("status-warn")
            self._diag_status_lbl.setText("Completed with warnings.")
            self._diag_status_lbl.setObjectName("status-warn")
        else:
            self._status_lbl.setText("All checks passed.")
            self._status_lbl.setObjectName("status-ok")
            self._diag_status_lbl.setText("All checks passed.")
            self._diag_status_lbl.setObjectName("status-ok")
        _restyle(self._status_lbl)
        _restyle(self._diag_status_lbl)

        self._diag_report.setPlainText(_diagnostics_report(probes))
        self._diag_copy_btn.setEnabled(True)
        self._diag_save_btn.setEnabled(True)

    def _on_failed(self, message: str):
        self._progress.hide()
        self._refresh_btn.setEnabled(True)
        self._diag_refresh_btn.setEnabled(True)
        _finish_worker(self)
        self._status_lbl.setText(f"Probe failed: {message}")
        self._status_lbl.setObjectName("status-err")
        _restyle(self._status_lbl)
        self._diag_status_lbl.setText(f"Failed: {message}")
        self._diag_status_lbl.setObjectName("status-err")
        _restyle(self._diag_status_lbl)

    def _copy_diag_report(self):
        QApplication.clipboard().setText(self._diag_report.toPlainText())
        self._diag_status_lbl.setText("Report copied to clipboard.")
        self._diag_status_lbl.setObjectName("status-ok")
        _restyle(self._diag_status_lbl)

    def _save_diag_report(self):
        default = os.path.expanduser(
            f"~/Documents/kyth-diagnostics-{datetime.now().strftime('%Y%m%d-%H%M%S')}.txt"
        )
        path, _ = QFileDialog.getSaveFileName(
            self, "Save Diagnostics Report", default, "Text Files (*.txt);;All Files (*)"
        )
        if not path:
            return
        try:
            with open(path, "w", encoding="utf-8") as fh:
                fh.write(self._diag_report.toPlainText())
            self._diag_status_lbl.setText(f"Saved to {path}.")
            self._diag_status_lbl.setObjectName("status-ok")
        except OSError as exc:
            self._diag_status_lbl.setText(f"Could not save: {exc}")
            self._diag_status_lbl.setObjectName("status-err")
        _restyle(self._diag_status_lbl)


