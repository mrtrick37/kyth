#!/usr/bin/env python3
"""kyth-welcome — KythOS System Hub entry point.

The application lives in the kyth_welcome package, installed at
/usr/lib/kyth-welcome on the OS image. A source checkout keeps the
package next to this script, which takes precedence for development.
"""

import os
import sys

_here = os.path.dirname(os.path.realpath(__file__))
for _candidate in (_here, "/usr/lib/kyth-welcome"):
    if os.path.isdir(os.path.join(_candidate, "kyth_welcome")):
        if _candidate not in sys.path:
            sys.path.insert(0, _candidate)
        break

from kyth_welcome.app import main

if __name__ == "__main__":
    main()
