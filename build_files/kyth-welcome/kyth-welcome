        self._diag_copy_btn.setEnabled(False)
        self._diag_copy_btn.clicked.connect(self._copy_diag_report)
        diag_btn_row.addWidget(self._diag_copy_btn)
        self._diag_save_btn = QPushButton("Save Report…")
