    # ── Create box ─────────────────────────────────────────────────────────────

    def _create_box(self):
        if self._worker and self._worker.isRunning():
            return

        if self._radio_everything.isChecked():
            meta = "kali-linux-everything"
        elif self._radio_default.isChecked():
            meta = "kali-linux-default"
        else:
            meta = "kali-linux-headless"
        self._last_install_meta = meta
        has_gui = meta in ("kali-linux-default", "kali-linux-everything")

        self._create_btn.setEnabled(False)
        for rb in (self._radio_headless, self._radio_default, self._radio_everything):
            rb.setEnabled(False)
        self._log.clear()
        export_note = (
            f"→ distrobox enter {self._BOX_NAME} -- distrobox-export (bulk GUI apps)\n"
            "→ kbuildsycoca6 (refresh KDE application menu)\n"
        ) if has_gui else ""
        size_note = (
            "\n⚠ kali-linux-everything is very large — this may take a long time.\n"
        ) if meta == "kali-linux-everything" else (
            "\nThis pulls the Kali container image and installs the tool metapackage.\n"
            "The first run will take a few minutes depending on your connection.\n"
        )
        self._log.append(
            f"→ distrobox create --image {self._BOX_IMAGE} --name {self._BOX_NAME}\n"
            f"→ distrobox enter {self._BOX_NAME} -- sudo apt-get install -y {meta}\n"
            + export_note + size_note
        )
        self._log_toggle.show()
        _set_log_panel(self._log_toggle, self._log, False)
        self._progress.setRange(0, 100)
        self._progress.setValue(2)
        self._progress.show()
        self._status_lbl.setText("Pulling Kali container image…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.show()
        _restyle(self._status_lbl)
        # Phase-tracking state for _on_create_line
        self._install_phase = 0       # 0=pull 1=init 2=apt-update 3=download 4=unpack 5=setup
        self._total_packages = 0      # parsed from apt "N newly installed"
        self._unpack_count = 0
        self._setup_count = 0

        export_step = (
            f" && distrobox enter {self._BOX_NAME} --"
            r" bash -c 'for f in /usr/share/applications/*.desktop;"
            r" do app=$(basename $f .desktop);"
            r" distrobox-export --app $app 2>/dev/null || true; done'"
            "\n_d=\"$HOME/.local/share/applications\"\n"
            "for _f in \"$_d/\"*.desktop; do\n"
            "    [[ -f \"$_f\" ]] || continue\n"
            "    grep -qE -- '--name kali|-n kali' \"$_f\" 2>/dev/null || continue\n"
            "    if grep -q '^Categories=' \"$_f\"; then\n"
            "        sed -i 's|^Categories=.*|Categories=X-KythSecurity;|' \"$_f\"\n"
            "    else\n"
            "        printf '\\nCategories=X-KythSecurity;\\n' >> \"$_f\"\n"
            "    fi\n"
            "    sed -i '/^NoDisplay[[:space:]]*=[[:space:]]*true/Id' \"$_f\"\n"
            "    sed -i '/^OnlyShowIn[[:space:]]*=/d' \"$_f\"\n"
            "done\n"
            "update-desktop-database \"$_d\" 2>/dev/null || true\n"
            "kbuildsycoca6 --noincremental 2>/dev/null || true"
        ) if has_gui else ""
        cmd = [
            "bash", "-c",
            f"distrobox create --image {self._BOX_IMAGE} --name {self._BOX_NAME} --yes"
            f" && distrobox enter {self._BOX_NAME} -- sudo apt-get install -y {meta}"
            + export_step,
        ]
        self._worker = Worker(cmd)
        self._worker.line.connect(self._on_create_line)
        self._worker.done.connect(self._on_create_done)
        self._worker.start()

    def _on_create_line(self, ln: str):
        self._log.append(ln)
        self._log.ensureCursorVisible()

        lo = ln.lower()
        phase = self._install_phase

        # ── Phase 0 / 1: Pulling the container image (2–42 %) ───────────────
        if phase <= 1:
            if any(k in lo for k in (
                "trying to pull", "pulling image", "getting image source",
                "copying blob", "copying config",
            )):
                self._install_phase = 1
                self._status_lbl.setText("Pulling Kali container image…")
                _restyle(self._status_lbl)
                cur = self._progress.value()
                if cur < 40:
                    self._progress.setValue(cur + 1)
                return
            if "writing manifest" in lo or "storing signatures" in lo:
                self._install_phase = 1
                self._progress.setValue(42)
                return
            # Distrobox init lines — image was cached or pull just finished
            if any(k in lo for k in (
                "container kali", "creating container", "starting container",
                "image is now available", "image already present",
            )) or (phase == 1 and "distrobox" in lo and "creat" in lo):
                self._install_phase = 2
                self._status_lbl.setText("Initialising Kali container…")
                _restyle(self._status_lbl)
                self._progress.setValue(max(self._progress.value(), 44))
                return

        # ── Phase 2: Container init / first boot (42–55 %) ───────────────────
        if phase == 2:
            if any(k in lo for k in ("installing basic", "bootstrapping", "reading package")):
                self._install_phase = 3
                self._status_lbl.setText("Updating package lists…")
                _restyle(self._status_lbl)
                self._progress.setValue(max(self._progress.value(), 55))
            else:
                cur = self._progress.value()
                if cur < 54:
                    self._progress.setValue(cur + 1)
            return

        # ── Phase 3: apt updating package lists (55–60 %) ────────────────────
        if phase == 3:
            if any(k in lo for k in ("reading package lists", "building dependency",
                                     "reading state information")):
                self._status_lbl.setText("Updating package lists…")
                _restyle(self._status_lbl)
                cur = self._progress.value()
                if cur < 59:
                    self._progress.setValue(cur + 1)
            elif any(k in lo for k in ("following new package", "following additional",
                                       "will be installed")):
                self._status_lbl.setText("Resolving dependencies…")
                _restyle(self._status_lbl)
                self._progress.setValue(max(self._progress.value(), 58))
            # "0 upgraded, N newly installed" — grab total package count
            m = re.search(r'(\d+) newly installed', ln)
            if m:
                self._total_packages = int(m.group(1))
            # "Need to get X MB of archives" — transition to download phase
            if "need to get" in lo and "archive" in lo:
                self._install_phase = 4
                self._status_lbl.setText("Downloading packages…")
                _restyle(self._status_lbl)
                self._progress.setValue(max(self._progress.value(), 60))
            return

        # ── Phase 4: Downloading packages (60–75 %) ──────────────────────────
        if phase == 4:
            m = re.match(r'Get:(\d+)\s', ln)
            if m:
                n = int(m.group(1))
                if self._total_packages > 0:
                    frac = min(1.0, n / self._total_packages)
                    self._progress.setValue(max(self._progress.value(),
                                               int(60 + frac * 15)))
                else:
                    cur = self._progress.value()
                    if cur < 74:
                        self._progress.setValue(cur + 1)
            if ln.startswith("Selecting previously") or ln.startswith("Preparing to unpack"):
                self._install_phase = 5
                self._status_lbl.setText("Unpacking packages…")
                _restyle(self._status_lbl)
                self._progress.setValue(max(self._progress.value(), 75))
            return

        # ── Phase 5: Unpacking (75–88 %) ─────────────────────────────────────
        if phase == 5:
            if ln.startswith("Unpacking "):
                self._unpack_count += 1
                if self._total_packages > 0:
                    frac = min(1.0, self._unpack_count / self._total_packages)
                    self._progress.setValue(max(self._progress.value(),
                                               int(75 + frac * 13)))
                else:
                    cur = self._progress.value()
                    if cur < 87:
                        self._progress.setValue(cur + 1)
            if ln.startswith("Setting up "):
                self._install_phase = 6
                self._status_lbl.setText("Configuring packages…")
                _restyle(self._status_lbl)
                self._setup_count = 1
                if self._total_packages > 0:
                    frac = min(1.0, 1 / self._total_packages)
                    self._progress.setValue(max(self._progress.value(),
                                               int(88 + frac * 10)))
                else:
                    self._progress.setValue(max(self._progress.value(), 88))
            return

        # ── Phase 6: Setting up / configuring (88–98 %) ──────────────────────
        if phase == 6:
            if ln.startswith("Setting up "):
                self._setup_count += 1
                if self._total_packages > 0:
                    frac = min(1.0, self._setup_count / self._total_packages)
                    self._progress.setValue(max(self._progress.value(),
                                               int(88 + frac * 10)))
                else:
                    cur = self._progress.value()
                    if cur < 97:
                        self._progress.setValue(cur + 1)
            if "processing triggers" in lo:
                self._status_lbl.setText("Finishing up…")
                _restyle(self._status_lbl)
                self._progress.setValue(max(self._progress.value(), 98))

    def _on_create_done(self, code: int):
        self._progress.setValue(100)
        self._progress.hide()
        _finish_worker(self, attr="_worker")
        self._create_btn.setEnabled(True)
        for rb in (self._radio_headless, self._radio_default, self._radio_everything):
            rb.setEnabled(True)
        if code == 0:
            meta = getattr(self, "_last_install_meta", "kali-linux-headless")
            if meta in ("kali-linux-default", "kali-linux-everything"):
                self._status_lbl.setText(
                    "Kali box created. GUI apps exported — check your application menu."
                )
            else:
                self._status_lbl.setText("Kali box created. Launch a terminal to start hacking.")
            self._status_lbl.setObjectName("status-ok")
            self._log.append("\nDone.")
        else:
            self._status_lbl.setText(f"Setup failed (exit {code}). Check the details below.")
            self._status_lbl.setObjectName("status-err")
        _restyle(self._status_lbl)
        self._refresh_status()

    # ── Enter box ──────────────────────────────────────────────────────────────

    def _enter_box(self):
        terminal = None
        for cmd in (["konsole"], ["xdg-terminal-exec"], ["xterm"]):
            if shutil.which(cmd[0]):
                terminal = cmd[0]
                break
        if terminal is None:
            QMessageBox.warning(self, "Terminal not found",
                                "Could not find a terminal emulator to open.")
            return

        if terminal == "konsole":
            subprocess.Popen(["konsole", "-e", "distrobox", "enter", self._BOX_NAME])
        else:
            subprocess.Popen([terminal, "--", "distrobox", "enter", self._BOX_NAME])

    # ── Export apps ────────────────────────────────────────────────────────────

    def _export_apps(self):
        if self._worker and self._worker.isRunning():
            return
        self._export_count = 0
        self._export_btn.setEnabled(False)
        self._enter_btn.setEnabled(False)
        self._remove_btn.setEnabled(False)
        self._log.clear()
        self._log.append(
            f"→ distrobox enter {self._BOX_NAME} -- distrobox-export (bulk GUI apps)\n"
            "→ kbuildsycoca6 (refresh KDE application menu)\n\n"
            "Scanning Kali container for GUI apps…\n"
        )
        self._log_toggle.show()
        _set_log_panel(self._log_toggle, self._log, False)
        self._progress.show()
        self._status_lbl.setText("Scanning for GUI apps…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.show()
        _restyle(self._status_lbl)

        # Exit 2 = no .desktop files found (headless-only install)
        # Prints "EXPORTED:<n>" on stdout so we can parse the count
        cmd = [
            "bash", "-c",
            # Step 1: export from inside the container
            f"distrobox enter {self._BOX_NAME} --"
            r" bash -c '"
            r"shopt -s nullglob; files=(/usr/share/applications/*.desktop);"
            r" if [ ${#files[@]} -eq 0 ]; then exit 2; fi;"
            r" n=0; for f in ${files[@]}; do"
            r"   app=$(basename $f .desktop);"
            r"   distrobox-export --app $app 2>&1 && n=$((n+1)) || echo skip: $app;"
            r" done; echo EXPORTED:$n'"
            # Step 2: patch host-side .desktop files — set Categories=X-KythSecurity;
            # strip NoDisplay/OnlyShowIn so entries appear in the launcher
            "\n_rc=$?; [ \"$_rc\" -eq 2 ] && exit 2\n"
            "_d=\"$HOME/.local/share/applications\"\n"
            "for _f in \"$_d/\"*.desktop; do\n"
            "    [[ -f \"$_f\" ]] || continue\n"
            "    grep -qE -- '--name kali|-n kali' \"$_f\" 2>/dev/null || continue\n"
            "    if grep -q '^Categories=' \"$_f\"; then\n"
            "        sed -i 's|^Categories=.*|Categories=X-KythSecurity;|' \"$_f\"\n"
            "    else\n"
            "        printf '\\nCategories=X-KythSecurity;\\n' >> \"$_f\"\n"
            "    fi\n"
            "    sed -i '/^NoDisplay[[:space:]]*=[[:space:]]*true/Id' \"$_f\"\n"
            "    sed -i '/^OnlyShowIn[[:space:]]*=/d' \"$_f\"\n"
            "done\n"
            "update-desktop-database \"$_d\" 2>/dev/null || true\n"
            "kbuildsycoca6 --noincremental 2>/dev/null || true",
        ]
        self._worker = Worker(cmd)
        self._worker.line.connect(self._on_export_line)
        self._worker.done.connect(self._on_export_done)
        self._worker.start()

    def _on_export_line(self, ln: str):
        if ln.startswith("EXPORTED:"):
            try:
                self._export_count = int(ln.split(":", 1)[1].strip())
            except ValueError:
                pass
        else:
            self._log.append(ln)
            self._log.ensureCursorVisible()

    def _on_export_done(self, code: int):
        self._progress.hide()
        _finish_worker(self, attr="_worker")
        self._export_btn.setEnabled(True)
        self._enter_btn.setEnabled(True)
        self._remove_btn.setEnabled(True)
        if code == 2:
            # No .desktop files in the container — headless install
            self._status_lbl.setText(
                "No GUI apps found. kali-linux-headless only includes CLI tools. "
                "Re-create the box with 'Default' or 'Everything' to get exportable GUI apps."
            )
            self._status_lbl.setObjectName("status-err")
            self._log.append(
                "\nNo .desktop files found inside the Kali container.\n"
                "kali-linux-headless does not ship GUI apps — there is nothing to export.\n"
                "To get GUI apps (Zenmap, Autopsy, Faraday, etc.), remove this box and\n"
                "re-create it with the 'Default' or 'Everything' tier."
            )
        elif code == 0:
            n = getattr(self, "_export_count", 0)
            if n == 0:
                self._status_lbl.setText(
                    "No GUI apps exported. kali-linux-headless contains CLI tools only — "
                    "remove this box and re-create it with 'Default' or 'Everything' "
                    "to get exportable GUI apps (Zenmap, Autopsy, Faraday, etc.)."
                )
                self._status_lbl.setObjectName("status-err")
                _set_log_panel(self._log_toggle, self._log, True)
            else:
                self._status_lbl.setText(
                    f"Exported {n} app(s) — they should appear in your application menu shortly. "
                    "If you don't see them, try logging out and back in."
                )
                self._status_lbl.setObjectName("status-ok")
            self._log.append("\nDone.")
        else:
            self._status_lbl.setText(f"Export failed (exit {code}). Check the details below.")
            self._status_lbl.setObjectName("status-err")
        _restyle(self._status_lbl)

    # ── Remove box ─────────────────────────────────────────────────────────────

    def _remove_box(self):
        if self._worker and self._worker.isRunning():
            return
        reply = QMessageBox.question(
            self, "Remove Kali Box",
            "Remove the Kali distrobox container?\n\nFiles in your home directory are not affected.",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.Cancel,
        )
        if reply != QMessageBox.StandardButton.Yes:
            return

        self._enter_btn.setEnabled(False)
        self._remove_btn.setEnabled(False)
        self._log.clear()
        self._log.append(f"→ distrobox rm --force {self._BOX_NAME}\n")
        self._log_toggle.show()
        _set_log_panel(self._log_toggle, self._log, False)
        self._progress.show()
        self._status_lbl.setText("Removing Kali box…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.show()
        _restyle(self._status_lbl)

        self._worker = Worker(["distrobox", "rm", "--force", self._BOX_NAME])
        self._worker.line.connect(lambda ln: (
            self._log.append(ln),
            self._log.ensureCursorVisible(),
        ))
        self._worker.done.connect(self._on_remove_done)
        self._worker.start()

    def _on_remove_done(self, code: int):
        self._progress.hide()
        _finish_worker(self, attr="_worker")
        self._enter_btn.setEnabled(True)
        self._remove_btn.setEnabled(True)
        if code == 0:
            self._status_lbl.setText("Kali box removed.")
            self._status_lbl.setObjectName("status-ok")
            self._log.append("\nDone.")
        else:
            self._status_lbl.setText(f"Removal failed (exit {code}).")
            self._status_lbl.setObjectName("status-err")
        _restyle(self._status_lbl)
        self._refresh_status()

