        self._dl_downloaded = 0
        self._dl_speed = 0
        self._dl_eta = 0
        self._dl_final_bytes = 0
        self._dl_low_speed_ticks = 0
        self._mode = mode
        self._last_output_ts = time.monotonic()
        self._op_start_ts = time.monotonic()
        self._current_phase = ""
        self._log.clear()
        self._log_toggle.show()
        self._set_log_expanded(False)
