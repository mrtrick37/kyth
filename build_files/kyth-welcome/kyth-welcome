    # ── Navigation ────────────────────────────────────────────────────────────

    def _update_nav(self):
        idx = self._current
        total = len(self._steps)
        install_busy = bool(
            self._wizard_extra_worker and self._wizard_extra_worker.isRunning()
        )

        for i, (dot, lbl) in enumerate(self._step_label_widgets):
            if i < idx:
                dot.setObjectName("step-dot-done")
                lbl.setObjectName("wizard-progress-step-done")
            elif i == idx:
                dot.setObjectName("step-dot-active")
                lbl.setObjectName("wizard-progress-step-active")
            else:
                dot.setObjectName("step-dot-inactive")
                lbl.setObjectName("wizard-progress-step")
            _restyle(dot)
            _restyle(lbl)

        self._back_btn.setVisible(idx > 0)
        self._skip_btn.setVisible(0 < idx < total - 1)
        self._back_btn.setEnabled(not install_busy)
        self._skip_btn.setEnabled(not install_busy)
        self._next_btn.setEnabled(not install_busy)

        if idx == total - 1:
            self._next_btn.setText("Close")
        elif idx == 0:
            self._next_btn.setText("Get Started  →")
        else:
            self._next_btn.setText("Next  →")

    def _go_back(self):
        if self._current > 0:
            self._current -= 1
            self._stack.setCurrentIndex(self._current)
            self._update_nav()

    def _go_next(self):
        if self._current == len(self._steps) - 1:
            _mark_wizard_done()
            self.close()
        else:
            self._current += 1
            self._stack.setCurrentIndex(self._current)
            self._update_nav()

    def closeEvent(self, event):
        if self._wizard_extra_worker and self._wizard_extra_worker.isRunning():
            QMessageBox.warning(
                self,
                "KythOS Is Busy",
                "Optional apps are still installing. Please wait for the install to finish before closing.",
            )
            event.ignore()
            self.raise_()
            self.activateWindow()
            return
        _mark_wizard_done()
        super().closeEvent(event)


# ── Entry point ───────────────────────────────────────────────────────────────
def main():
    # Parse --page PAGEKEY before QApplication (which may strip unrecognised args)
    start_page = None
    raw_args = sys.argv[1:]
    for i, a in enumerate(raw_args):
        if a == "--page" and i + 1 < len(raw_args):
            start_page = raw_args[i + 1]

    _wait_for_display_setup()
    _prefer_xwayland_if_wayland_plugin_missing()

    app = QApplication(sys.argv)
    app.setApplicationName("kyth-welcome")
    app.setDesktopFileName("kyth-welcome")
    app.setWindowIcon(QIcon.fromTheme("kyth"))
    app.setStyleSheet(QSS)

    win = WizardWindow() if _is_first_run() else MainWindow()
    win.setWindowIcon(QIcon.fromTheme("kyth"))
    win.show()
    if start_page and isinstance(win, MainWindow):
        win._navigate_to(start_page)
    _remove_autostart()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
