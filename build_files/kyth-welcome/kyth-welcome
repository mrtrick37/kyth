            for icon, label, key, factory in items:
                page_specs.append((key, factory))
                btn = NavButton(icon, label)
                btn.clicked.connect(self._make_nav_handler(global_idx))
                sidebar_layout.addWidget(btn)
                self._nav_buttons.append(btn)
                global_idx += 1
