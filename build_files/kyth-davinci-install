#!/usr/bin/env bash
set -euo pipefail

DOWNLOAD_DIR="${XDG_DOWNLOAD_DIR:-}"
if [[ -z "${DOWNLOAD_DIR}" ]] && command -v xdg-user-dir >/dev/null 2>&1; then
    DOWNLOAD_DIR="$(xdg-user-dir DOWNLOAD 2>/dev/null || true)"
fi
if [[ -z "${DOWNLOAD_DIR}" || ! -d "${DOWNLOAD_DIR}" ]]; then
    DOWNLOAD_DIR="${HOME}/Downloads"
fi

find_latest_zip() {
    local root candidate latest="" latest_mtime=0 mtime=0
    while IFS= read -r -d '' candidate; do
        mtime="$(stat -c '%Y' "${candidate}" 2>/dev/null || echo 0)"
        if (( mtime >= latest_mtime )); then
            latest="${candidate}"
            latest_mtime="${mtime}"
        fi
    done < <(
        for root in "${DOWNLOAD_DIR}" "${HOME}/Downloads"; do
            [[ -d "${root}" ]] || continue
            find "${root}" -maxdepth 2 -type f \
                \( -iname 'DaVinci_Resolve*_Linux.zip' \
                   -o -iname 'DaVinci_Resolve_Studio*_Linux.zip' \
                   -o -iname '*DaVinci*Resolve*Linux*.zip' \) \
                -print0 2>/dev/null
        done
    )

    [[ -n "${latest}" ]] || return 1
    printf '%s\n' "${latest}"
}

ZIP_PATH="${1:-}"
if [[ -z "${ZIP_PATH}" ]]; then
    ZIP_PATH="$(find_latest_zip || true)"
fi
if [[ "${ZIP_PATH}" == ~/* ]]; then
    ZIP_PATH="${HOME}/${ZIP_PATH#~/}"
fi

if [[ -z "${ZIP_PATH}" || ! -f "${ZIP_PATH}" ]]; then
    echo "ERROR: No DaVinci Resolve Linux ZIP was found."
    echo "Download the Linux ZIP from Blackmagic first, or pick it manually in the welcome app."
    exit 2
fi

for tool in git flatpak flatpak-builder unzip; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
        echo "ERROR: Missing required tool: ${tool}"
        echo "Please update KythOS and try again."
        exit 3
    fi
done

CACHE_ROOT="${XDG_CACHE_HOME:-${HOME}/.cache}/kyth/davinci-resolve"
SRC_DIR="${CACHE_ROOT}/resolve-flatpak"
WORK_DIR="${CACHE_ROOT}/work"
BUILD_DIR="${CACHE_ROOT}/build-dir"
mkdir -p "${CACHE_ROOT}"

echo "Using ZIP: ${ZIP_PATH}"
echo "Preparing the Resolve Flatpak helper sources…"
# Pinned to a specific commit for supply-chain integrity.
# To update: verify the new commit in the repo, then change both values.
RESOLVE_FLATPAK_COMMIT="000efab2df0cc781a47dff13321bfdb688aad14f"  # 2026-03-01
if [[ -d "${SRC_DIR}/.git" ]]; then
    if ! git -C "${SRC_DIR}" fetch --depth=1 origin "${RESOLVE_FLATPAK_COMMIT}"; then
        echo "Warning: couldn't refresh the helper sources, using the cached copy instead."
    else
        git -C "${SRC_DIR}" reset --hard "${RESOLVE_FLATPAK_COMMIT}" >/dev/null
    fi
else
    rm -rf "${SRC_DIR}"
    git clone --recurse-submodules \
        "https://github.com/pobthebuilder/resolve-flatpak.git" \
        "${SRC_DIR}"
    git -C "${SRC_DIR}" checkout "${RESOLVE_FLATPAK_COMMIT}"
fi

if [[ ! -d "${SRC_DIR}/.git" ]]; then
    echo "ERROR: Couldn't prepare the Resolve Flatpak helper sources."
    exit 4
fi

git -C "${SRC_DIR}" submodule update --init --recursive

rm -rf "${WORK_DIR}" "${BUILD_DIR}"
mkdir -p "${WORK_DIR}" "${BUILD_DIR}"

echo "Extracting the official Blackmagic download…"
unzip -qo "${ZIP_PATH}" -d "${WORK_DIR}"
RUN_FILE="$(find "${WORK_DIR}" -maxdepth 2 -type f \( -iname 'DaVinci_Resolve*_Linux.run' -o -iname 'DaVinci_Resolve_Studio*_Linux.run' \) | head -n 1 || true)"
if [[ -z "${RUN_FILE}" ]]; then
    echo "ERROR: The selected ZIP doesn't contain a DaVinci Resolve Linux installer (.run)."
    exit 5
fi

RUN_NAME="$(basename "${RUN_FILE}")"
cp -f "${RUN_FILE}" "${SRC_DIR}/${RUN_NAME}"
chmod +x "${SRC_DIR}/${RUN_NAME}"

APP_ID="com.blackmagic.Resolve"
MANIFEST="com.blackmagic.Resolve.yaml"
if [[ "${RUN_NAME}" == *Studio* ]]; then
    APP_ID="com.blackmagic.ResolveStudio"
    MANIFEST="com.blackmagic.ResolveStudio.yaml"
fi

echo "Building ${APP_ID} as a user Flatpak…"
(
    cd "${SRC_DIR}"
    flatpak-builder \
        --user \
        --install \
        --install-deps-from=flathub \
        --force-clean \
        "${BUILD_DIR}" \
        "${MANIFEST}"
)

if flatpak info "${APP_ID}" >/dev/null 2>&1; then
    echo
    echo "Success: ${APP_ID} is installed."
    exit 0
fi

echo "ERROR: The build finished but ${APP_ID} is not available in Flatpak."
exit 6
