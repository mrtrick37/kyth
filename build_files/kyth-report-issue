#!/usr/bin/env bash
set -euo pipefail

repo_url="${KYTH_ISSUE_REPO_URL:-https://github.com/mrtrick37/kyth}"
title="KythOS issue report"
body=""
body_file=""
label="${KYTH_ISSUE_LABEL:-bug}"
open_browser=1

usage() {
    cat <<'EOF'
Usage: kyth-report-issue [--title TITLE] [--body TEXT] [--body-file PATH] [--label LABEL] [--no-open]

Creates a prefilled GitHub issue URL for KythOS, writes a local draft copy,
and opens the browser unless --no-open is passed.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --title)
            title="${2:-}"
            shift 2
            ;;
        --body)
            body="${2:-}"
            shift 2
            ;;
        --body-file)
            body_file="${2:-}"
            shift 2
            ;;
        --label)
            label="${2:-}"
            shift 2
            ;;
        --no-open)
            open_browser=0
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "kyth-report-issue: unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ -n "${body_file}" ]]; then
    if [[ -r "${body_file}" ]]; then
        body="$(cat "${body_file}")"
    else
        echo "kyth-report-issue: body file is not readable: ${body_file}" >&2
        exit 1
    fi
fi

if [[ -z "${body}" ]]; then
    body="Describe what happened, what you expected, and what you were doing just before it happened."
fi

draft_dir="${XDG_STATE_HOME:-${HOME}/.local/state}/kyth"
mkdir -p "${draft_dir}"
draft="${draft_dir}/github-issue-$(date +%Y%m%d-%H%M%S).md"
{
    printf '# %s\n\n' "${title}"
    printf '%s\n' "${body}"
} > "${draft}"

url="$(
    python3 - "${repo_url}" "${title}" "${body}" "${label}" <<'PY'
import sys
from urllib.parse import urlencode

repo_url, title, body, label = sys.argv[1:5]
max_body = 5500
if len(body) > max_body:
    body = (
        body[:max_body]
        + "\n\n[Report body truncated for the browser URL. A full local draft was saved by kyth-report-issue.]"
    )
params = {"title": title, "body": body}
if label:
    params["labels"] = label
print(repo_url.rstrip("/") + "/issues/new?" + urlencode(params))
PY
)"

echo "Draft saved: ${draft}"
echo "${url}"

if [[ "${open_browser}" -eq 1 ]]; then
    if command -v xdg-open >/dev/null 2>&1; then
        nohup xdg-open "${url}" >/dev/null 2>&1 &
    else
        echo "Open this URL to file the issue:" >&2
        echo "${url}" >&2
    fi
fi
