#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR=/etc/scx
CONFIG_FILE="${CONFIG_DIR}/scx_loader.conf"
SERVICE=scx_loader.service

usage() {
    cat <<'HELPEOF'
Usage: kyth-scx <status|list|set|restart|stop> [scheduler]

Examples:
  kyth-scx status
  kyth-scx list
  kyth-scx set lavd
  kyth-scx set rusty
  kyth-scx stop
HELPEOF
}

need_root() {
    if [[ "${EUID}" -eq 0 ]]; then
        return 0
    fi
    exec sudo -A /usr/bin/kyth-scx "$@"
}

normalise_scheduler() {
    local sched=$1
    case "$sched" in
        lavd|rusty|bpfland|flash|tickless|chaos|layered|rlfifo)
            printf 'scx_%s\n' "$sched"
            ;;
        scx_*)
            printf '%s\n' "$sched"
            ;;
        *)
            printf 'scx_%s\n' "$sched"
            ;;
    esac
}

installed_schedulers() {
    find /usr/bin -maxdepth 1 -type f -name 'scx_*' -printf '%f\n' 2>/dev/null \
        | grep -Ev '^scx_loader$' \
        | sort
}

active_scheduler() {
    if [[ -r "$CONFIG_FILE" ]]; then
        awk -F= '/^SCX_SCHEDULER=/{print $2; exit}' "$CONFIG_FILE"
    fi
}

cmd="${1:-status}"
case "$cmd" in
    status)
        echo "Configured scheduler: $(active_scheduler || true)"
        if [[ -r /sys/kernel/sched_ext/state ]]; then
            echo "Kernel sched_ext state: $(cat /sys/kernel/sched_ext/state)"
        fi
        systemctl --no-pager --quiet is-active "$SERVICE" \
            && echo "Service: active" \
            || echo "Service: inactive"
        ;;
    list)
        installed_schedulers
        ;;
    set)
        need_root "$@"
        scheduler="${2:-}"
        [[ -n "$scheduler" ]] || { usage >&2; exit 1; }
        scheduler="$(normalise_scheduler "$scheduler")"
        if ! command -v "$scheduler" >/dev/null 2>&1; then
            echo "${scheduler} is not installed." >&2
            echo "Installed schedulers:" >&2
            installed_schedulers >&2 || true
            exit 1
        fi
        install -d -m 0755 "$CONFIG_DIR"
        printf 'SCX_SCHEDULER=%s\n' "$scheduler" > "$CONFIG_FILE"
        systemctl enable "$SERVICE" >/dev/null 2>&1 || true
        systemctl restart "$SERVICE"
        echo "Active sched-ext scheduler set to ${scheduler}."
        ;;
    restart)
        need_root "$@"
        systemctl restart "$SERVICE"
        echo "Restarted ${SERVICE}."
        ;;
    stop)
        need_root "$@"
        systemctl disable --now "$SERVICE"
        echo "Stopped sched-ext loader. Kernel default scheduler is active."
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
