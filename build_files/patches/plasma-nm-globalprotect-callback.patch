+void OpenconnectAuthWidget::handleWebEngineNavigation(QWebEngineNavigationRequest &request)
+{
+    // GlobalProtect SAML delivers the preloginuserauthcookie via a redirect to
+    // globalprotectcallback:// — a custom URL scheme Qt WebEngine doesn't know
+    // and silently aborts before urlChanged fires.  Intercept it here (before
+    // Qt drops the navigation) so openconnect_webview_load_changed can extract
+    // the cookie from the URL.
+    const QString scheme = request.url().scheme();
+    if (scheme == QLatin1String("globalprotectcallback") || scheme == QLatin1String("gc")) {
+        handleWebEngineUrl(request.url());
+        request.reject();
+    }
+}
