#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 ]]; then
    echo "Usage: ${0##*/} BOX COMMAND [ARGS...]" >&2
    exit 2
fi

box="$1"
shift

# Root GUI apps often fail from desktop launchers with "No protocol specified"
# unless the display server allows the local root user before sudo is invoked.
if command -v xhost >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
    xhost +SI:localuser:root >/dev/null 2>&1 \
        || xhost +si:localuser:root >/dev/null 2>&1 \
        || true
fi

exec distrobox enter "${box}" -- bash -lc '
    if command -v xhost >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
        xhost +SI:localuser:root >/dev/null 2>&1 \
            || xhost +si:localuser:root >/dev/null 2>&1 \
            || true
    fi
    # Root cannot access the Wayland socket in /run/user/<uid>/ (drwx------ owned
    # by the login user).  Force X11/XWayland, which xhost already grants root
    # access to, so GTK apps do not SIGABRT trying to connect to Wayland.
    export GDK_BACKEND=x11
    unset WAYLAND_DISPLAY
    # breeze-dark (mounted from host /usr/local) ships SVG icons that glycin
    # loads via bwrap --unshare-all. That sandbox call fails when root runs
    # inside a container, causing a Gtk:ERROR assertion crash. Force the
    # PNG-only hicolor fallback theme to sidestep the glycin sandbox entirely.
    export GTK_ICON_THEME=hicolor
    exec sudo -E "$@"
' bash "$@"
