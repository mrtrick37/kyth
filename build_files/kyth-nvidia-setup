#!/bin/bash
# kyth-nvidia-setup — first-boot NVIDIA driver auto-builder.
#
# Runs once at boot. If an NVIDIA GPU is detected and no kernel module exists,
# blacklists nouveau/nova_core and builds akmod-nvidia for the running kernel.
#
# Flag file written on completion (success) or when no NVIDIA hardware is
# present, so the service does not run again. If akmods fails the flag is NOT
# written, allowing a retry on the next boot.

set -euo pipefail

FLAG="/var/lib/kyth/nvidia-setup-done"
mkdir -p /var/lib/kyth

# No NVIDIA GPU — nothing to do.
if ! lspci | grep -qi nvidia; then
    touch "${FLAG}"
    exit 0
fi

# Driver already built for this kernel — nothing to do.
if modinfo nvidia &>/dev/null; then
    touch "${FLAG}"
    exit 0
fi

# akmod-nvidia not yet layered — user must install it first.
# Exit without writing FLAG so this service retries on the next boot after they do.
if ! rpm -q akmod-nvidia &>/dev/null; then
    echo "kyth-nvidia-setup: akmod-nvidia not installed — run: ujust install-nvidia-driver"
    exit 0
fi

echo "kyth-nvidia-setup: NVIDIA GPU detected — building kernel module via akmods"
echo "kyth-nvidia-setup: this may take 5-15 minutes on first boot"

# Blacklist nouveau and nova_core, enable DRM modesetting.
# Matches the kernel args set by the kyth-welcome NVIDIA page.
KARGS="rd.driver.blacklist=nouveau,nova_core modprobe.blacklist=nouveau,nova_core nvidia-drm.modeset=1"
# grubby works on both GRUB2 and systemd-boot BLS entries on Fedora, but it
# can silently do nothing on some configurations (e.g. non-standard ESP layout
# or bootc-managed deployments that haven't been rebooted yet). Make it
# non-fatal: the kargs are already baked into the image via kargs.d, so the
# driver will still load correctly after the next bootc-applied reboot even if
# grubby fails to update the current boot entry.
if ! grubby --update-kernel=ALL --args="${KARGS}"; then
    echo "kyth-nvidia-setup: grubby could not update kernel args (non-fatal — kargs.d will apply on next deployment)"
fi

# Build the module for the running kernel.
akmods --force --kernels "$(uname -r)"

touch "${FLAG}"
echo "kyth-nvidia-setup: done — reboot to activate NVIDIA drivers"
