# KythOS live ISO installer image.
# Built on top of the same image the installer writes to disk — the live
# desktop is a real preview of KythOS, not a separate shell.
#
# Build with:
#   sudo podman build --cap-add SYS_ADMIN --security-opt label=disable \
#     --build-arg BASE_IMAGE=ghcr.io/mrtrick37/kyth:latest \
#     --build-arg SOURCE_TAG=latest \
#     -t kyth-live:build -f installer/Containerfile .

ARG BASE_IMAGE=ghcr.io/mrtrick37/kyth:latest
FROM ${BASE_IMAGE}
ARG BASE_IMAGE
ARG SOURCE_TAG=latest

# Override dnf mirrors with direct URLs (faster, more reliable than mirror lists)
RUN mkdir -p /etc/yum.repos.d.bak && \
    mv /etc/yum.repos.d/*.repo /etc/yum.repos.d.bak/ 2>/dev/null || true && \
    printf '%s\n' \
        '[fedora]' \
        'name=Fedora $releasever - $basearch' \
        'metalink=https://mirrors.fedoraproject.org/metalink?repo=fedora-$releasever&arch=$basearch' \
        'enabled=1' \
        'countme=1' \
        'metadata_expire=7d' \
        > /etc/yum.repos.d/fedora.repo

RUN --mount=type=bind,source=installer/build.sh,target=/src/installer/build.sh \
    --mount=type=bind,source=installer/iso.yaml,target=/src/installer/iso.yaml \
    --mount=type=bind,source=build_files/scripts/plymouth-branding-guard.sh,target=/src/build_files/scripts/plymouth-branding-guard.sh \
    --mount=type=bind,source=build_files/kyth-installer,target=/src/build_files/kyth-installer \
    --mount=type=bind,source=build_files/kyth-launch-installer,target=/src/build_files/kyth-launch-installer \
    --mount=type=bind,source=build_files/kyth-partition-install.sh,target=/src/build_files/kyth-partition-install.sh \
    env BASE_IMAGE="${BASE_IMAGE}" SOURCE_TAG="${SOURCE_TAG}" \
    bash /src/installer/build.sh
