# Pull the upstream Fedora bootc base and apply mt-OS branding.
# Build with: podman build -t localhost/mt-os-base:stable build_base/
# Override the base via: podman build --build-arg BASE_IMAGE=... build_base/
ARG BASE_IMAGE=quay.io/fedora/fedora-bootc:43
FROM ${BASE_IMAGE}

# Use a bind-mount so the script is never written into any image layer
RUN --mount=type=bind,source=build.sh,target=/run/build.sh,relabel=shared \
    bash /run/build.sh
